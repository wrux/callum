---
import { Icon } from 'astro-icon/components';
import ArticleTeaser from '~/components/ArticleTeaser.astro';
import HeroMedia from '~/components/HeroMedia.astro';
import Logo from '~/components/Logo.astro';
import TeaserGrid from '~/components/TeaserGrid.astro';
import Wordmark from '~/components/Wordmark.astro';
import { getLatestPosts } from '~/sanity/queries';
import BaseLayout from '~/layouts/BaseLayout.astro';

const posts = await getLatestPosts();
const featuredPost = posts[0];
const gridPosts = featuredPost ? posts.slice(1) : posts;
const heroImage = featuredPost?.mainImage;
const heroImageAlt = heroImage?.asset.alt || featuredPost?.title || '';
---

<BaseLayout
  meta={{
    title:
      'Exploring the World | callum.co.uk | Personal Travel Adventures Home',
    description:
      'Embark on a journey with Callum Bonnyman as they share their globetrotting to alternative and unknown places!',
  }}
>
  <section id="hero-section" class="home-hero media-hero">
    <HeroMedia image={heroImage} alt={heroImageAlt} />

    <div class="home-hero-content u-container u-container-6xl">
      <div class="home-hero-brand u-flex u-flex-col u-gap-2">
        <Logo class="t-logo-lg u-text-light home-hero-logo" />
        <Wordmark class="t-logo-md u-text-light home-hero-logo" />
      </div>

      <div class="home-hero-grid">
        <div class="home-hero-intro u-min-0">
          <h1 class="t-hero-title u-m-0 u-text-balance u-text-light">
            Journeys beyond the obvious
          </h1>
          <p class="t-hero-summary u-mt-4 u-mb-0 home-hero-summary u-text-soft">
            Photographs and field notes from less travelled places, shaped by
            curiosity, wandering, and a preference for the unusual route.
          </p>
        </div>

        {
          featuredPost && (
            <aside
              class="home-hero-latest"
              aria-labelledby="home-hero-latest-title"
            >
              <p class="t-overline home-hero-latest-label">Latest story</p>
              <h2
                class="t-h4 home-hero-latest-title"
                id="home-hero-latest-title"
              >
                {featuredPost.title}
              </h2>
              {featuredPost.excerpt && (
                <p class="t-card-summary home-hero-latest-summary">
                  {featuredPost.excerpt}
                </p>
              )}
              <a
                class="t-action btn btn-primary btn-action u-mt-2"
                href={`/article/${featuredPost.slug}`}
                aria-label={`Read article ${featuredPost.title}`}
              >
                <span>Read article</span>
                <span class="btn-chip" aria-hidden="true">
                  <Icon name="mdi:arrow-top-right" />
                </span>
              </a>
            </aside>
          )
        }
      </div>
    </div>
  </section>

  {
    gridPosts.length > 0 && (
      <section class="home-post-list">
        <TeaserGrid>
          {gridPosts.map((post, index) => (
            <ArticleTeaser
              {...post}
              lazy={index >= 3 ? index : undefined}
              priority={index === 0}
            />
          ))}
        </TeaserGrid>
      </section>
    )
  }
</BaseLayout>

<style>
  .home-hero {
    background:
      radial-gradient(
        circle at 20% 25%,
        rgb(26 77 230 / 0.34),
        transparent 24rem
      ),
      oklch(13% 0.028 261.692);
  }

  .home-post-list {
    padding-block: clamp(4rem, 2.75rem + 2.6vw, 5rem)
      clamp(6rem, 1rem + 10.4vw, 10rem);
  }

  .home-hero-latest-label {
    margin: 0;
    color: oklch(70.7% 0.022 261.325);
    transition:
      color 500ms cubic-bezier(0, 0, 0.2, 1),
      opacity 500ms cubic-bezier(0, 0, 0.2, 1);
  }

  .home-hero-logo {
    opacity: 0.95;
  }

  .home-hero-brand {
    width: fit-content;
  }

  .home-hero-summary {
    max-width: 36rem;
  }

  .home-hero-intro {
    max-width: 48rem;
  }

  .home-hero-latest-summary {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: oklch(87.2% 0.01 258.338);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
</style>
