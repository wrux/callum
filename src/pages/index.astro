---
import { ArticleTeaser, Logo, TeaserGrid, Wordmark } from '~/components';
import { Icon } from 'astro-icon/components';
import { getLatestPosts } from '~/sanity/queries';
import BaseLayout from '~/layouts/BaseLayout.astro';

const posts = await getLatestPosts();
---

<BaseLayout
  meta={{
    title:
      'Exploring the World | callum.co.uk | Personal Travel Adventures Home',
    description:
      'Embark on a journey with Callum Bonnyman as they share their globetrotting to alternative and unknwon places!',
  }}
>
  <div
    id="hero-section"
    class="flex flex-col items-center justify-center px-4 py-12 text-center md:py-16"
  >
    <div class="mb-10 flex flex-col items-center md:mb-12 lg:mb-14">
      <Logo class="mb-3 text-[4rem] opacity-90 md:text-[5rem] lg:text-[6rem]" />
      <Wordmark class:list="text-[3rem] md:text-[4rem] lg:text-[5rem]" />
    </div>

    <div class="mb-12 space-y-5 md:space-y-6 lg:space-y-7">
      <h1 class="type-h1">
        Journeys beyond the obvious,
        <span class="lg:block">shaped by curiosity</span>
      </h1>
      <p class="type-text-lg mx-auto max-w-2xl text-gray-300">
        Stories and photographs from journeys to places less traveled, capturing
        the essence of alternative destinations around the world.
      </p>
    </div>

    <div class="hero-glob-panel mx-auto w-full max-w-3xl">
      <div class="hero-glob-track">
        <div class="hero-glob-row">
          <span class="hero-glob hero-glob-small" aria-hidden="true">
            <span class="hero-glob-surface"></span>
            <Icon
              name="mdi:airplane"
              class="hero-glob-icon hero-glob-icon-plane"
            />
          </span>
          <span class="hero-glob hero-glob-large" aria-hidden="true">
            <span class="hero-glob-surface"></span>
            <Icon
              name="mdi:map-marker"
              class="hero-glob-icon hero-glob-icon-marker"
            />
          </span>
          <span class="hero-glob hero-glob-small" aria-hidden="true">
            <span class="hero-glob-surface"></span>
            <Icon
              name="mdi:camera"
              class="hero-glob-icon hero-glob-icon-camera"
            />
          </span>
        </div>
      </div>
    </div>
  </div>

  {
    posts.length > 0 && (
      <section class="home-posts">
        <TeaserGrid>
          {posts.map((post, index) => (
            <ArticleTeaser
              {...post}
              lazy={index >= 3 ? index : undefined}
              priority={index === 0}
            />
          ))}
        </TeaserGrid>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero-glob-panel {
    background: var(--color-gray-950);
  }

  .hero-glob-track {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-glob-track::before {
    position: absolute;
    inset-block-start: 50%;
    inset-inline: 0;
    height: 1px;
    content: '';
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-gray-700),
      transparent
    );
  }

  .hero-glob-row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-inline: 1.5rem;
  }

  .hero-glob {
    --hero-glob-size: 3rem;
    --hero-glob-icon-size: 1.25rem;

    position: relative;
    display: grid;
    width: var(--hero-glob-size);
    aspect-ratio: 1;
    place-items: center;
    color: var(--color-gray-50);
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-glob-small {
    --hero-glob-size: 2.75rem;
    --hero-glob-icon-size: 1.15rem;
  }

  .hero-glob-large {
    --hero-glob-size: 4rem;
    --hero-glob-icon-size: 1.75rem;
  }

  .hero-glob-surface {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    filter: url(#buttonFilter);
  }

  .hero-glob-surface::before,
  .hero-glob-surface::after {
    position: absolute;
    content: '';
    background: var(--color-brand-medium);
    border-radius: 999px;
    transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-glob-surface::before {
    inset: 0;
  }

  .hero-glob-surface::after {
    inset-block-start: 0.12rem;
    inset-inline-end: -0.22rem;
    width: 42%;
    aspect-ratio: 1;
  }

  .hero-glob :global(.hero-glob-icon) {
    position: relative;
    z-index: 1;
    width: var(--hero-glob-icon-size);
    height: var(--hero-glob-icon-size);
    transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-glob :global(.hero-glob-icon-plane),
  .hero-glob :global(.hero-glob-icon-camera) {
    transform: rotate(-15deg);
  }

  .hero-glob:hover {
    transform: translateY(-3px);
  }

  .hero-glob:hover .hero-glob-surface::after {
    transform: translate(4px, -3px);
  }

  .hero-glob:hover :global(.hero-glob-icon-plane),
  .hero-glob:hover :global(.hero-glob-icon-camera) {
    transform: translateX(2px) rotate(-28deg);
  }

  .hero-glob:hover :global(.hero-glob-icon-marker) {
    transform: translateY(-2px) scale(1.08);
  }

  .home-posts {
    padding-block-end: clamp(6rem, 10vw, 10rem);
  }

  @media (width >= 48rem) {
    .hero-glob-row {
      gap: 1.5rem;
    }
  }
</style>
