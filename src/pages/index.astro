---
import {
  ArticleTeaser,
  Logo,
  Section,
  TeaserGrid,
  Wordmark,
} from '~/components';
import { Icon } from 'astro-icon/components';
import { getLatestPosts } from '~/sanity/queries';
import BaseLayout from '~/layouts/BaseLayout.astro';

const posts = await getLatestPosts();
---

<BaseLayout
  meta={{
    title:
      'Exploring the World | callum.co.uk | Personal Travel Adventures Home',
    description:
      'Embark on a journey with Callum Bonnyman as they share their globetrotting to alternative and unknwon places!',
  }}
>
  <div
    id="hero-section"
    class="flex flex-col items-center justify-center px-4 py-12 text-center md:py-16"
  >
    <div class="mb-10 flex flex-col items-center md:mb-12 lg:mb-14">
      <Logo class="mb-3 text-[4rem] opacity-90 md:text-[5rem] lg:text-[6rem]" />
      <Wordmark class:list="text-[3rem] md:text-[4rem] lg:text-[5rem]" />
    </div>

    <div class="mb-12 space-y-5 md:space-y-6 lg:space-y-7">
      <h1 class="type-h1">
        Journeys beyond the obvious,
        <span class="lg:block">shaped by curiosity</span>
      </h1>
      <p class="type-text-lg mx-auto max-w-2xl text-gray-300">
        Stories and photographs from journeys to places less traveled, capturing
        the essence of alternative destinations around the world.
      </p>
    </div>

    <div class="mx-auto w-full max-w-3xl bg-gray-950">
      <div class="relative flex items-center justify-center">
        <div class="absolute inset-0 flex items-center">
          <div
            class="h-px w-full bg-gradient-to-r from-transparent via-gray-700 to-transparent"
          >
          </div>
        </div>
        <div class="relative flex items-center gap-5 px-6 md:gap-6">
          <div
            class="group flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-gray-950 shadow-sm backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:shadow-md md:h-12 md:w-12"
          >
            <Icon
              name="mdi:airplane"
              class="h-3 w-3 rotate-[-15deg] text-white transition-transform duration-300 group-hover:rotate-[-25deg] md:h-5 md:w-5"
            />
          </div>
          <div
            class="group flex h-14 w-14 items-center justify-center rounded-full border border-white/20 bg-gray-950 shadow-sm backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:shadow-md md:h-16 md:w-16"
          >
            <Icon
              name="mdi:map-marker"
              class="h-6 w-6 text-white transition-transform duration-300 group-hover:scale-110 md:h-7 md:w-7"
            />
          </div>
          <div
            class="group flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-gray-950 shadow-sm backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:shadow-md md:h-12 md:w-12"
          >
            <Icon
              name="mdi:camera"
              class="h-3 w-3 rotate-[-15deg] text-white transition-transform duration-300 group-hover:rotate-[-25deg] md:h-5 md:w-5"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  {
    posts.length > 0 && (
      <TeaserGrid>
        {posts.map((post, index) => (
          <ArticleTeaser
            {...post}
            lazy={index >= 3 ? index : undefined}
            priority={index === 0}
          />
        ))}
      </TeaserGrid>
    )
  }
</BaseLayout>
