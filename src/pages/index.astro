---
import { ArticleTeaser, Logo, TeaserGrid, Wordmark } from '~/components';
import { Icon } from 'astro-icon/components';
import { createImageUrlBuilder } from '@sanity/image-url';
import { getLatestPosts } from '~/sanity/queries';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { sanityClient } from 'sanity:client';

const posts = await getLatestPosts();
const featuredPost = posts[0];
const gridPosts = featuredPost ? posts.slice(1) : posts;
const heroImage = featuredPost?.mainImage;
const heroImageBuilder = createImageUrlBuilder(sanityClient)
  .fit('crop')
  .format('webp');
const heroImageWidths = [640, 960, 1280, 1600, 1920, 2400];
const heroImageHeightForWidth = (width: number) => Math.round(width / 2);
const heroImageSrc =
  heroImage &&
  heroImageBuilder
    .image(heroImage)
    .width(1600)
    .height(heroImageHeightForWidth(1600))
    .quality(78)
    .url();
const heroImageSrcSet =
  heroImage &&
  heroImageWidths
    .map((width) => {
      const url = heroImageBuilder
        .image(heroImage)
        .width(width)
        .height(heroImageHeightForWidth(width))
        .quality(78)
        .url();

      return `${url} ${width}w`;
    })
    .join(', ');
const heroImageAlt = heroImage?.asset.alt || featuredPost?.title || '';
const featuredPostHeroMediaTransitionName = featuredPost
  ? `post-hero-media-${featuredPost.slug}`
  : undefined;
---

<BaseLayout
  meta={{
    title:
      'Exploring the World | callum.co.uk | Personal Travel Adventures Home',
    description:
      'Embark on a journey with Callum Bonnyman as they share their globetrotting to alternative and unknown places!',
  }}
>
  <section
    id="hero-section"
    class="home-hero relative isolate grid grid-cols-[minmax(0,1fr)] overflow-hidden before:col-start-1 before:row-start-1 before:block before:aspect-[2/1] before:w-full before:content-['']"
    data-has-image={heroImageSrc ? 'true' : 'false'}
  >
    {
      heroImageSrc && (
        <figure
          class="home-hero-media absolute inset-0 z-[-2] m-0 h-full w-full overflow-hidden opacity-0 transition-opacity duration-700 data-[image-loaded=true]:opacity-80"
          transition:name={featuredPostHeroMediaTransitionName}
          transition:animate="none"
        >
          <img
            class="h-full w-full object-cover brightness-50"
            src={heroImageSrc}
            srcset={heroImageSrcSet}
            sizes="100vw"
            alt={heroImageAlt}
            width="1600"
            height={heroImageHeightForWidth(1600)}
            decoding="async"
            fetchpriority="high"
            loading="eager"
          />
        </figure>
      )
    }
    <div class="absolute inset-0 z-[-1] h-full w-full bg-gray-950/20" aria-hidden="true"></div>

    <div class="container relative col-start-1 row-start-1 flex w-full min-w-0 max-w-6xl flex-col justify-between gap-11 pt-24 pb-8 md:gap-14 md:pt-24 md:pb-10 lg:pt-36">
      <div class="flex w-fit flex-col gap-2.5">
        <Logo class="type-home-logo-mark text-gray-50 opacity-95" />
        <Wordmark class="type-home-wordmark text-gray-50 opacity-95" />
      </div>

      <div class="grid min-w-0 gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,26rem)] lg:items-end lg:gap-16">
        <div class="min-w-0 max-w-3xl">
          <h1 class="type-hero-title m-0 text-balance text-gray-50">
            Journeys beyond the obvious
          </h1>
          <p class="type-hero-summary mt-5 mb-0 max-w-xl text-gray-200">
            Photographs and field notes from less travelled places, shaped by
            curiosity, wandering, and a preference for the unusual route.
          </p>
        </div>

        {
          featuredPost && (
            <aside
              class="home-hero-latest group/latest relative isolate flex min-w-0 max-w-md flex-col items-start gap-2 border-t border-white/30 pt-4 text-gray-50 md:gap-2.5 lg:justify-self-end"
              aria-labelledby="home-hero-latest-title"
            >
              <p class="type-overline m-0 text-gray-400 transition-all duration-500 ease-out">
                Latest story
              </p>
              <h2
                class="type-feature-title m-0 whitespace-normal text-gray-50 transition-colors duration-200 group-hover/latest:text-brand-light group-focus-within/latest:text-brand-light"
                id="home-hero-latest-title"
              >
                {featuredPost.title}
              </h2>
              {featuredPost.excerpt && (
                <p class="type-card-summary m-0 line-clamp-3 overflow-hidden text-gray-300">
                  {featuredPost.excerpt}
                </p>
              )}
              <a
                class="type-action bubble-arrow-link mt-2"
                href={`/article/${featuredPost.slug}`}
                aria-label={`Read article ${featuredPost.title}`}
              >
                <span class="bubble-arrow-link__surface" aria-hidden="true" />
                Read article
                <Icon
                  name="mdi:arrow-top-right"
                  class="bubble-arrow-link__icon"
                  aria-hidden="true"
                />
              </a>
            </aside>
          )
        }
      </div>
    </div>
  </section>

  {
    gridPosts.length > 0 && (
      <section class="pt-16 pb-24 md:pt-20 md:pb-32 lg:pb-40">
        <TeaserGrid>
          {gridPosts.map((post, index) => (
            <ArticleTeaser
              {...post}
              lazy={index >= 3 ? index : undefined}
              priority={index === 0}
            />
          ))}
        </TeaserGrid>
      </section>
    )
  }
</BaseLayout>

<style>
  .home-hero {
    background:
      radial-gradient(
        circle at 20% 25%,
        color-mix(in srgb, var(--color-brand-medium) 34%, transparent),
        transparent 24rem
      ),
      var(--color-gray-950);
  }

  .home-hero-media {
    mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    mask-repeat: no-repeat;
    mask-size: 100% 100%;
    -webkit-mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
  }
</style>
