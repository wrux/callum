---
import { imageBuilder } from '~/sanity/image';
import { createImageUrlBuilder } from '@sanity/image-url';
import { sanityClient } from 'sanity:client';
import SanityPicture from 'astro-sanity-picture';
import { Icon } from 'astro-icon/components';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { DateTime, PortableText } from '~/components';
import { getPosts } from '~/sanity/queries';

// Create a cropped image builder for main images with fixed 2:1 aspect ratio
const baseCroppedBuilder = createImageUrlBuilder(sanityClient)
  .fit('crop')
  .format('webp');

// Create a proxy wrapper to ensure 2:1 aspect ratio is maintained.
// Sanity's URL builder is immutable, so use the returned builder from width/height
// calls to preserve dimensions before hotspot/crop rects are calculated.
const croppedImageBuilder = new Proxy(baseCroppedBuilder, {
  get(target, prop) {
    if (prop === 'image') {
      return (source: any) => {
        const builder = target.image(source);

        return new Proxy(builder, {
          get(imageTarget, imageProp) {
            if (imageProp === 'width') {
              return (width: number) =>
                imageTarget.width(width).height(Math.round(width / 2));
            }

            if (imageProp === 'height') {
              return (height: number) =>
                imageTarget.width(Math.round(height * 2)).height(height);
            }

            const value = (imageTarget as any)[imageProp];
            return typeof value === 'function'
              ? value.bind(imageTarget)
              : value;
          },
        });
      };
    }

    const value = (target as any)[prop];
    return typeof value === 'function' ? value.bind(target) : value;
  },
});

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

export type Props = Article;

const post = Astro.props as Article;
const heroImageHotspot = post.mainImage?.hotspot as
  | { x?: number; y?: number }
  | undefined;
const heroImagePosition =
  heroImageHotspot?.x != null && heroImageHotspot?.y != null
    ? `${heroImageHotspot.x * 100}% ${heroImageHotspot.y * 100}%`
    : '50% 50%';
---

<BaseLayout
  meta={{
    title: `${post.title} | callum.co.uk`,
    description: post.excerpt,
    image:
      post.mainImage &&
      imageBuilder.image(post.mainImage).width(1600).height(900).url(),
  }}
>
  <article class="article-page">
    <header
      class="article-hero"
      data-has-image={post.mainImage ? 'true' : 'false'}
    >
      {
        post?.mainImage && (
          <figure
            class="article-hero-media"
            style={`--article-hero-image-position: ${heroImagePosition};`}
          >
            <SanityPicture
              class="article-hero-picture"
              src={post.mainImage}
              imageUrlBuilder={croppedImageBuilder}
              sizes="100vw"
              widths={[640, 960, 1280, 1600, 1920, 2400]}
              sources={[{ options: { quality: 78 } }]}
              img={{
                alt: post.mainImage.asset.alt || post.title || '',
                class: 'article-hero-image',
                decoding: 'async',
                fetchpriority: 'high',
                loading: 'eager',
              }}
            />
            {post.mainImage?.alt && (
              <figcaption class="sr-only">{post.mainImage.alt}</figcaption>
            )}
          </figure>
        )
      }

      <div class="article-hero-overlay" aria-hidden="true"></div>

      <div class="article-hero-inner container max-w-6xl">
        <div class="article-hero-copy">
          {
            post?.countries?.length > 0 && (
              <ul class="article-hero-countries" aria-label="Countries">
                {post.countries.map((country) => (
                  <li>
                    <span class="article-hero-country">
                      <Icon
                        name="mdi:map-marker"
                        class="article-hero-country-icon"
                      />
                      <span>{country.name}</span>
                    </span>
                  </li>
                ))}
              </ul>
            )
          }

          <h1 class="article-hero-title">
            {post.title}
          </h1>

          {post?.excerpt && <p class="article-hero-excerpt">{post.excerpt}</p>}

          {
            post?.publishedAt && (
              <p class="article-hero-date">
                <Icon
                  name="mdi:calendar-blank-outline"
                  class="article-hero-date-icon"
                />
                <span>
                  Published on <DateTime date={post.publishedAt} />
                </span>
              </p>
            )
          }

          {
            (post?.imageCount || post?.readingTime) && (
              <dl class="article-hero-meta" aria-label="Article details">
                {post?.readingTime && (
                  <div class="article-hero-meta-item">
                    <dt>Reading time</dt>
                    <dd>
                      <Icon
                        name="mdi:clock-outline"
                        class="article-hero-meta-icon"
                      />
                      <span>{post.readingTime} min read</span>
                    </dd>
                  </div>
                )}
                {post?.imageCount && (
                  <div class="article-hero-meta-item">
                    <dt>Images</dt>
                    <dd>
                      <Icon
                        name="mdi:image-multiple-outline"
                        class="article-hero-meta-icon"
                      />
                      <span>
                        {post.imageCount} image{post.imageCount > 1 ? 's' : ''}
                      </span>
                    </dd>
                  </div>
                )}
              </dl>
            )
          }
        </div>
      </div>
    </header>

    <div class="article-content">
      <PortableText value={post.content} />
    </div>
  </article>
</BaseLayout>

<script>
  function initArticleHeroImageFade() {
    const images = document.querySelectorAll('.article-hero-image');

    images.forEach((image) => {
      if (!(image instanceof HTMLImageElement)) {
        return;
      }

      const markLoaded = () => {
        requestAnimationFrame(() => {
          image.dataset.isLoaded = 'true';
          image
            .closest('.article-hero-media')
            ?.setAttribute('data-image-loaded', 'true');
        });
      };

      if (image.complete && image.naturalWidth > 0) {
        markLoaded();
        return;
      }

      image.addEventListener('load', markLoaded, { once: true });
    });
  }

  initArticleHeroImageFade();
  document.addEventListener('astro:page-load', initArticleHeroImageFade);
</script>

<style>
  .article-page {
    background:
      radial-gradient(
        circle at 88% 14%,
        color-mix(in srgb, var(--color-brand-medium) 18%, transparent),
        transparent 21rem
      ),
      var(--color-gray-950);
  }

  .article-hero {
    --hero-image-aspect-ratio: 2 / 1;

    position: relative;
    isolation: isolate;
    display: grid;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 18% 22%,
        color-mix(in srgb, var(--color-brand-medium) 34%, transparent),
        transparent 25rem
      ),
      var(--color-gray-950);
  }

  .article-hero::before {
    display: block;
    grid-area: 1 / 1;
    width: 100%;
    aspect-ratio: var(--hero-image-aspect-ratio);
    content: '';
  }

  .article-hero-media,
  .article-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    aspect-ratio: var(--hero-image-aspect-ratio);
  }

  .article-hero-media {
    z-index: -2;
    margin: 0;
    overflow: hidden;
    mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    mask-repeat: no-repeat;
    mask-size: 100% 100%;
    opacity: 0;
    transition: opacity 720ms ease;
    -webkit-mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
  }

  .article-hero-media[data-image-loaded='true'] {
    opacity: 0.8;
  }

  .article-hero :global(.article-hero-picture) {
    width: 100%;
    height: 100%;
  }

  .article-hero :global(.article-hero-image) {
    width: 100%;
    height: 100%;
    filter: brightness(0.56);
    object-fit: cover;
    object-position: var(--article-hero-image-position, 50% 50%);
  }

  .article-hero-overlay {
    z-index: -1;
    background: rgb(3 7 18 / 0.18);
  }

  .article-hero-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start;
    padding-block: 6rem 2.5rem;
  }

  .article-hero-copy {
    max-width: 58rem;
  }

  .article-hero-countries {
    display: flex;
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
    gap: 0.1rem;
    margin: 0 0 1.25rem;
    padding: 0;
    list-style: none;
    filter: url(#buttonFilter);
  }

  .article-hero-country {
    display: inline-flex;
    min-height: 1.9rem;
    align-items: center;
    gap: 0.28rem;
    border-radius: 999px;
    background: var(--color-brand-medium);
    padding-inline: 0.62rem 0.72rem;
    color: var(--color-gray-50);
    font-size: 0.75rem;
    font-weight: 750;
    line-height: 1;
  }

  .article-hero-country :global(.article-hero-country-icon) {
    width: 0.82rem;
    height: 0.82rem;
  }

  .article-hero-title {
    max-width: 14ch;
    margin: 0;
    color: var(--color-gray-50);
    font-size: clamp(2.75rem, 6vw, 4.75rem);
    font-weight: 850;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .article-hero-excerpt {
    max-width: 42rem;
    margin: 1.35rem 0 0;
    color: var(--color-gray-200);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.62;
  }

  .article-hero-date {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 1.15rem 0 0;
    border-radius: 999px;
    background: rgb(3 7 18 / 0.1);
    padding: 0.2rem 0.85rem 0.2rem 0.2rem;
    color: var(--color-gray-200);
    font-size: 0.9375rem;
    line-height: 1;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .article-hero-date :global(.article-hero-date-icon) {
    box-sizing: content-box;
    flex: 0 0 auto;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: var(--color-brand-medium);
    padding: 0.35rem;
    color: var(--color-gray-50);
  }

  .article-hero-date :global(time) {
    font-weight: 700;
    letter-spacing: 0;
  }

  .article-hero-meta {
    display: flex;
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
    gap: 0.18rem;
    margin: 1rem 0 0;
    filter: url(#buttonFilter);
  }

  .article-hero-meta-item {
    margin: 0;
  }

  .article-hero-meta-item dt {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .article-hero-meta-item dd {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.11);
    padding-inline: 1rem;
    color: var(--color-gray-100);
    font-size: 0.9rem;
    font-weight: 720;
    line-height: 1;
    backdrop-filter: blur(18px);
  }

  .article-hero-meta-item :global(.article-hero-meta-icon) {
    width: 1.05rem;
    height: 1.05rem;
  }

  .article-content {
    padding-block: clamp(3rem, 7vw, 5rem) 1rem;
  }

  @media (width >= 64rem) {
    .article-hero-inner {
      padding-block: 8.75rem 2.5rem;
    }
  }

  @media (width < 48rem) {
    .article-hero-inner {
      padding-block: 5.75rem 2rem;
    }

    .article-hero-title {
      max-width: 11ch;
    }

    .article-hero-countries,
    .article-hero-meta {
      filter: none;
    }
  }
</style>
