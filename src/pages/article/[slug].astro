---
import { imageBuilder } from '~/sanity/image';
import { createImageUrlBuilder } from '@sanity/image-url';
import { sanityClient } from '~/sanity/client';
import { Icon } from 'astro-icon/components';
import BaseLayout from '~/layouts/BaseLayout.astro';
import DateTime from '~/components/DateTime.astro';
import PortableText from '~/components/PortableText.astro';
import TableOfContentsList from '~/components/TableOfContentsList.astro';
import { getPosts } from '~/sanity/queries';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

export type Props = Article;

const post = Astro.props as Article;
const heroImageHotspot = post.mainImage?.hotspot as
  | { x?: number; y?: number }
  | undefined;
const heroImagePosition =
  heroImageHotspot?.x != null && heroImageHotspot?.y != null
    ? `${heroImageHotspot.x * 100}% ${heroImageHotspot.y * 100}%`
    : '50% 50%';
const heroImageBuilder = createImageUrlBuilder(sanityClient)
  .fit('crop')
  .format('webp');
const heroImageDesktopWidths = [1280, 1600, 1920, 2400];
const heroImageTabletWidths = [768, 1024, 1280, 1536];
const heroImageMobileWidths = [480, 640, 828, 960];
const heroImageHeightForAspect = (width: number, aspectRatio: number) =>
  Math.round(width / aspectRatio);
const heroImageSrcSetForAspect = (widths: number[], aspectRatio: number) =>
  post.mainImage &&
  widths
    .map((width) => {
      const url = heroImageBuilder
        .image(post.mainImage)
        .width(width)
        .height(heroImageHeightForAspect(width, aspectRatio))
        .quality(78)
        .url();

      return `${url} ${width}w`;
    })
    .join(', ');
const heroImageSrc =
  post.mainImage &&
  heroImageBuilder
    .image(post.mainImage)
    .width(1600)
    .height(heroImageHeightForAspect(1600, 2))
    .quality(78)
    .url();
const heroImageMobileSrcSet = heroImageSrcSetForAspect(
  heroImageMobileWidths,
  9 / 19.5,
);
const heroImageTabletSrcSet = heroImageSrcSetForAspect(
  heroImageTabletWidths,
  1,
);
const heroImageDesktopSrcSet = heroImageSrcSetForAspect(
  heroImageDesktopWidths,
  2,
);
const heroImageAlt = post.mainImage?.asset.alt || post.title || '';
const hasReadingTime =
  typeof post.readingTime === 'number' && post.readingTime > 0;
const countryNames = post.countries
  ?.map((country) => country.name)
  .filter(Boolean)
  .join(', ');

type PortableTextChild = {
  text?: string;
};

type PortableTextHeadingBlock = {
  _key?: string;
  _type?: string;
  children?: PortableTextChild[];
  style?: string;
};

type ArticleContentBlock = {
  _type?: string;
  content?: PortableTextHeadingBlock[];
};

type TableOfContentsItem = {
  children: TableOfContentsItem[];
  depth: number;
  href: string;
  text: string;
};

const headingLevels = new Set(['h1', 'h2', 'h3', 'h4', 'h5', 'h6']);
const getHeadingDepth = (style: string) => Number(style.replace('h', '')) || 2;
const getHeadingText = (block: PortableTextHeadingBlock) =>
  block.children
    ?.map((child) => child.text)
    .filter(Boolean)
    .join('')
    .trim() || '';

const tableOfContents = ((post.content || []) as ArticleContentBlock[])
  .flatMap((contentBlock) => contentBlock.content || [])
  .filter(
    (block) =>
      block._type === 'block' &&
      block._key &&
      block.style &&
      headingLevels.has(block.style) &&
      getHeadingText(block),
  )
  .map(
    (block): TableOfContentsItem => ({
      children: [],
      depth: getHeadingDepth(block.style as string),
      href: `#heading-${block._key}`,
      text: getHeadingText(block),
    }),
  );

const buildTableOfContentsTree = (headings: TableOfContentsItem[]) => {
  const tree: TableOfContentsItem[] = [];
  const stack: TableOfContentsItem[] = [];

  headings.forEach((heading) => {
    const item = { ...heading, children: [] };

    while (stack.length > 0 && heading.depth <= stack[stack.length - 1].depth) {
      stack.pop();
    }

    const parent = stack[stack.length - 1];

    if (parent) {
      parent.children.push(item);
    } else {
      tree.push(item);
    }

    stack.push(item);
  });

  return tree;
};

const tableOfContentsTree = buildTableOfContentsTree(tableOfContents);

const showTableOfContents = tableOfContents.length > 1;
---

<BaseLayout
  meta={{
    title: `${post.title} | callum.co.uk`,
    description: post.excerpt,
    image:
      post.mainImage &&
      imageBuilder.image(post.mainImage).width(1600).height(900).url(),
  }}
>
  <article class="article-page bg-gray-950">
    <header
      class="article-hero media-hero"
      data-has-image={heroImageSrc ? 'true' : 'false'}
    >
      {
        heroImageSrc && (
          <figure
            class="article-hero-media media-hero-asset media-hero-asset-article"
            style={`--article-hero-image-position: ${heroImagePosition};`}
          >
            <picture>
              <source
                media="(max-width: 767px)"
                srcset={heroImageMobileSrcSet}
                sizes="100vw"
              />
              <source
                media="(max-width: 1023px)"
                srcset={heroImageTabletSrcSet}
                sizes="100vw"
              />
              <img
                class="media-hero-image media-hero-image-article"
                src={heroImageSrc}
                srcset={heroImageDesktopSrcSet}
                sizes="100vw"
                alt={heroImageAlt}
                width="1600"
                height={heroImageHeightForAspect(1600, 2)}
                decoding="async"
                fetchpriority="high"
                loading="eager"
              />
            </picture>
            {post.mainImage?.alt && (
              <figcaption class="sr-only">{post.mainImage.alt}</figcaption>
            )}
          </figure>
        )
      }

      <div class="media-hero-scrim" aria-hidden="true"></div>

      <div class="article-hero-content container max-w-6xl">
        <div class="w-full max-w-4xl min-w-0">
          {
            countryNames && (
              <p
                class="goo-filter-md m-0 mb-5 flex w-fit max-w-full"
                aria-label="Countries"
              >
                <span class="type-pill bg-brand-medium inline-flex min-h-8 max-w-full items-center gap-1 rounded-full py-1.5 pr-3 pl-2.5 text-gray-50">
                  <Icon name="mdi:map-marker" class="size-3.5" />
                  <span class="min-w-0">{countryNames}</span>
                </span>
              </p>
            )
          }

          <h1 class="type-hero-title m-0 max-w-4xl text-balance text-gray-50">
            {post.title}
          </h1>

          {
            post?.excerpt && (
              <p class="type-hero-summary mt-5 mb-0 max-w-2xl text-gray-200">
                {post.excerpt}
              </p>
            )
          }

          {
            (post?.publishedAt || hasReadingTime) && (
              <div
                class="mt-5 flex w-full max-w-full min-w-0 flex-wrap items-center gap-2"
                aria-label="Article details"
              >
                {post?.publishedAt && (
                  <p class="type-meta m-0 inline-flex max-w-full items-center gap-2 rounded-full bg-gray-950/10 py-1 pr-3 pl-1 text-gray-200 backdrop-blur-lg">
                    <Icon
                      name="mdi:calendar-blank-outline"
                      class="bg-brand-medium box-content size-3.5 flex-none rounded-full p-1.5 text-gray-50"
                    />
                    <span class="min-w-0">
                      Published on <DateTime date={post.publishedAt} />
                    </span>
                  </p>
                )}

                {hasReadingTime && (
                  <p class="type-meta m-0 inline-flex max-w-full items-center gap-2 rounded-full bg-gray-950/10 py-1 pr-3 pl-1 text-gray-200 backdrop-blur-lg">
                    <Icon
                      name="mdi:book-open-page-variant-outline"
                      class="bg-brand-medium box-content size-3.5 flex-none rounded-full p-1.5 text-gray-50"
                    />
                    <span class="min-w-0">
                      Estimated{' '}
                      <strong class="type-meta-emphasis">
                        {post.readingTime} min read
                      </strong>
                    </span>
                  </p>
                )}
              </div>
            )
          }

          {
            showTableOfContents && (
              <nav class="mt-6 max-w-xl" aria-label="Table of contents">
                <p class="type-overline text-brand-light m-0 mb-3">
                  Table of Contents
                </p>
                <TableOfContentsList items={tableOfContentsTree} />
              </nav>
            )
          }
        </div>
      </div>
    </header>

    <div class="pt-12 pb-4 md:pt-16 lg:pt-20">
      <PortableText value={post.content} />
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    background:
      radial-gradient(
        circle at 88% 14%,
        color-mix(in srgb, var(--color-brand-medium) 18%, transparent),
        transparent 21rem
      ),
      var(--color-gray-950);
  }

  .article-hero {
    background:
      radial-gradient(
        circle at 18% 22%,
        color-mix(in srgb, var(--color-brand-medium) 34%, transparent),
        transparent 25rem
      ),
      var(--color-gray-950);
  }

  .article-hero-media {
    mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    mask-repeat: no-repeat;
    mask-size: 100% 100%;
    -webkit-mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
  }
</style>
