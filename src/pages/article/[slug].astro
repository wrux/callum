---
import { imageBuilder } from '~/sanity/image';
import { Icon } from 'astro-icon/components';
import BaseLayout from '~/layouts/BaseLayout.astro';
import DateTime from '~/components/DateTime.astro';
import HeroMedia from '~/components/HeroMedia.astro';
import PortableText from '~/components/PortableText.astro';
import TableOfContentsList from '~/components/TableOfContentsList.astro';
import { getPosts } from '~/sanity/queries';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

export type Props = Article;

const post = Astro.props as Article;
const heroImageHotspot = post.mainImage?.hotspot as
  | { x?: number; y?: number }
  | undefined;
const heroImagePosition =
  heroImageHotspot?.x != null && heroImageHotspot?.y != null
    ? `${heroImageHotspot.x * 100}% ${heroImageHotspot.y * 100}%`
    : '50% 50%';
const heroImageAlt = post.mainImage?.asset.alt || post.title || '';
const hasReadingTime =
  typeof post.readingTime === 'number' && post.readingTime > 0;
const countryNames = post.countries
  ?.map((country) => country.name)
  .filter(Boolean)
  .join(', ');

type PortableTextChild = {
  text?: string;
};

type PortableTextHeadingBlock = {
  _key?: string;
  _type?: string;
  children?: PortableTextChild[];
  style?: string;
};

type ArticleContentBlock = {
  _type?: string;
  content?: PortableTextHeadingBlock[];
};

type TableOfContentsItem = {
  children: TableOfContentsItem[];
  depth: number;
  href: string;
  text: string;
};

const headingLevels = new Set(['h1', 'h2', 'h3', 'h4', 'h5', 'h6']);
const getHeadingDepth = (style: string) => Number(style.replace('h', '')) || 2;
const getHeadingText = (block: PortableTextHeadingBlock) =>
  block.children
    ?.map((child) => child.text)
    .filter(Boolean)
    .join('')
    .trim() || '';

const tableOfContents = ((post.content || []) as ArticleContentBlock[])
  .flatMap((contentBlock) => contentBlock.content || [])
  .filter(
    (block) =>
      block._type === 'block' &&
      block._key &&
      block.style &&
      headingLevels.has(block.style) &&
      getHeadingText(block),
  )
  .map(
    (block): TableOfContentsItem => ({
      children: [],
      depth: getHeadingDepth(block.style as string),
      href: `#heading-${block._key}`,
      text: getHeadingText(block),
    }),
  );

const buildTableOfContentsTree = (headings: TableOfContentsItem[]) => {
  const tree: TableOfContentsItem[] = [];
  const stack: TableOfContentsItem[] = [];

  headings.forEach((heading) => {
    const item = { ...heading, children: [] };

    while (stack.length > 0 && heading.depth <= stack[stack.length - 1].depth) {
      stack.pop();
    }

    const parent = stack[stack.length - 1];

    if (parent) {
      parent.children.push(item);
    } else {
      tree.push(item);
    }

    stack.push(item);
  });

  return tree;
};

const tableOfContentsTree = buildTableOfContentsTree(tableOfContents);

const showTableOfContents = tableOfContents.length > 1;
---

<BaseLayout
  meta={{
    title: `${post.title} | callum.co.uk`,
    description: post.excerpt,
    image:
      post.mainImage &&
      imageBuilder.image(post.mainImage).width(1600).height(900).url(),
  }}
>
  <article class="article-page">
    <header class="article-hero media-hero">
      <HeroMedia
        image={post.mainImage}
        alt={heroImageAlt}
        caption={post.mainImage?.alt}
        position={heroImagePosition}
      />

      <div class="article-hero-content u-container u-container-6xl">
        <div class="u-full u-container-4xl u-min-0">
          {
            countryNames && (
              <p class="article-location-wrap" aria-label="Countries">
                <span class="t-pill article-location-pill">
                  <Icon name="mdi:map-marker" class="article-location-icon" />
                  <span class="u-min-0">{countryNames}</span>
                </span>
              </p>
            )
          }

          <h1
            class="t-hero-title u-m-0 u-container-4xl u-text-balance u-text-light"
          >
            {post.title}
          </h1>

          {
            post?.excerpt && (
              <p class="t-hero-summary u-mt-4 u-mb-0 u-container-2xl u-text-soft">
                {post.excerpt}
              </p>
            )
          }

          {
            (post?.publishedAt || hasReadingTime) && (
              <div
                class="article-meta-list u-mt-4 u-flex u-full u-min-0 u-gap-2"
                aria-label="Article details"
              >
                {post?.publishedAt && (
                  <p class="t-meta surface-glass article-meta-pill">
                    <Icon
                      name="mdi:calendar-blank-outline"
                      class="article-meta-icon"
                    />
                    <span class="u-min-0">
                      Published on <DateTime date={post.publishedAt} />
                    </span>
                  </p>
                )}

                {hasReadingTime && (
                  <p class="t-meta surface-glass article-meta-pill">
                    <Icon
                      name="mdi:book-open-page-variant-outline"
                      class="article-meta-icon"
                    />
                    <span class="u-min-0">
                      Estimated{' '}
                      <strong class="t-meta-emphasis">
                        {post.readingTime} min read
                      </strong>
                    </span>
                  </p>
                )}
              </div>
            )
          }

          {
            showTableOfContents && (
              <nav class="article-toc" aria-label="Table of contents">
                <p class="t-overline article-toc-label u-m-0 u-mb-3">
                  Table of Contents
                </p>
                <TableOfContentsList items={tableOfContentsTree} />
              </nav>
            )
          }
        </div>
      </div>
    </header>

    <div class="article-content-wrap">
      <PortableText value={post.content} />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .article-page {
    background:
      radial-gradient(
        circle at 88% 14%,
        rgb(26 77 230 / 0.18),
        transparent 21rem
      ),
      oklch(13% 0.028 261.692);
  }

  .article-hero {
    background:
      radial-gradient(
        circle at 18% 22%,
        rgb(26 77 230 / 0.34),
        transparent 25rem
      ),
      oklch(13% 0.028 261.692);
  }

  .article-toc {
    margin-top: 1.5rem;
    max-width: 36rem;
  }

  .article-toc-label {
    color: hsl(225 80% 70%);
  }

  .article-meta-list {
    align-items: center;
    flex-wrap: wrap;
  }

  .article-content-wrap {
    padding-block: clamp(3rem, 0.5rem + 5.2vw, 5rem) 1rem;
  }

  .hero-image-caption {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border-width: 0;
  }

  .article-meta-pill {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    min-width: 0;
    gap: 0.5rem;
    margin: 0;
    padding: 0.25rem 0.75rem 0.25rem 0.25rem;
    border-radius: 999px;
    color: oklch(92.8% 0.006 264.531);
  }

  .article-location-wrap {
    display: flex;
    width: fit-content;
    max-width: 100%;
    margin: 0 0 1rem;
  }

  .article-location-pill {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    min-height: 2rem;
    gap: 0.25rem;
    padding: 0.375rem 0.75rem 0.375rem 0.625rem;
    border-radius: 999px;
    color: oklch(98.5% 0.002 247.839);
    background: hsl(225 80% 50%);
  }

  .article-location-icon {
    flex: 0 0 auto;
    width: 0.875rem;
    height: 0.875rem;
  }

  .article-meta-icon {
    box-sizing: content-box;
    flex: 0 0 auto;
    width: 0.875rem;
    height: 0.875rem;
    padding: 0.375rem;
    border-radius: 999px;
    color: oklch(98.5% 0.002 247.839);
    background: hsl(225 80% 50%);
  }
</style>
