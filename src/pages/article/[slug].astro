---
import { imageBuilder } from '~/sanity/image';
import { createImageUrlBuilder } from '@sanity/image-url';
import { sanityClient } from 'sanity:client';
import SanityPicture from 'astro-sanity-picture';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { DateTime, PortableText } from '~/components';
import { getPosts } from '~/sanity/queries';

// Create a cropped image builder for main images with fixed 16:9 aspect ratio
const baseCroppedBuilder = createImageUrlBuilder(sanityClient)
  .fit('crop')
  .format('webp');

// Create a proxy wrapper to ensure 16:9 aspect ratio is maintained.
// Sanity's URL builder is immutable, so use the returned builder from width/height
// calls to preserve dimensions before hotspot/crop rects are calculated.
const croppedImageBuilder = new Proxy(baseCroppedBuilder, {
  get(target, prop) {
    if (prop === 'image') {
      return (source: any) => {
        const builder = target.image(source);

        return new Proxy(builder, {
          get(imageTarget, imageProp) {
            if (imageProp === 'width') {
              return (width: number) =>
                imageTarget.width(width).height(Math.round((width * 9) / 16));
            }

            if (imageProp === 'height') {
              return (height: number) =>
                imageTarget.width(Math.round((height * 16) / 9)).height(height);
            }

            const value = (imageTarget as any)[imageProp];
            return typeof value === 'function'
              ? value.bind(imageTarget)
              : value;
          },
        });
      };
    }

    const value = (target as any)[prop];
    return typeof value === 'function' ? value.bind(target) : value;
  },
});

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

export type Props = Article;

const post = Astro.props as Article;
---

<BaseLayout
  meta={{
    title: `${post.title} | callum.co.uk`,
    description: post.excerpt,
    image:
      post.mainImage &&
      imageBuilder.image(post.mainImage).width(1600).height(900).url(),
  }}
>
  <article class="pt-24 md:pt-0">
    <section class="mb-12 md:mb-16 lg:mb-20">
      <div class="container">
        <div class="mx-auto max-w-4xl py-6 text-center md:py-8 lg:py-12">
          {
            (post?.imageCount || post?.readingTime) && (
              <p class="type-text-sm type-text-muted mb-4 tracking-wide uppercase lg:mb-6">
                {[
                  post?.readingTime && `${post.readingTime} min read`,
                  post?.imageCount &&
                    `${post.imageCount} image${post.imageCount > 1 ? 's' : ''}`,
                ]
                  .filter(Boolean)
                  .join(' • ')}
              </p>
            )
          }
          {
            post?.countries && (
              <div class="mb-6 flex flex-wrap justify-center gap-2 lg:mb-8">
                <span class="sr-only">Countries: </span>
                {post.countries.map((country) => (
                  <span class="inline-block rounded-full border border-gray-700 bg-gray-800 px-4 py-1.5 text-sm font-medium text-gray-300">
                    {country.name}
                  </span>
                ))}
              </div>
            )
          }
          <h1 class="type-h1 mb-6 lg:mb-8">
            {post.title}
          </h1>
          {
            post?.excerpt && (
              <p class="type-text-lg mx-auto mb-8 max-w-3xl text-gray-300 lg:mb-10">
                {post.excerpt}
              </p>
            )
          }
          <p class="type-text-sm type-text-muted">
            Published <DateTime date={post.publishedAt} />
          </p>
        </div>
      </div>
      <div class="mt-8 w-full md:container md:max-w-screen-2xl lg:mt-12">
        {
          post?.mainImage && (
            <figure class="overflow-hidden border-0 border-gray-800 shadow-2xl md:rounded-2xl md:border">
              <div class="relative aspect-[16/9] overflow-hidden">
                <SanityPicture
                  src={post.mainImage}
                  imageUrlBuilder={croppedImageBuilder}
                  sizes="(max-width: 767px) 100vw, (max-width: 1535px) 90vw, 1344px"
                  widths={[640, 960, 1280, 1600, 1920]}
                  sources={[{ options: { quality: 76 } }]}
                  img={{
                    alt: post.mainImage.asset.alt || post.title || '',
                    class: 'w-full h-full object-cover',
                    decoding: 'async',
                    fetchpriority: 'high',
                    loading: 'eager',
                  }}
                />
              </div>
              {post.mainImage?.alt && (
                <figcaption class="sr-only">{post.mainImage.alt}</figcaption>
              )}
            </figure>
          )
        }
      </div>
    </section>

    <PortableText value={post.content} />
  </article>
</BaseLayout>
