---
import { imageBuilder } from '~/sanity/image';
import { createImageUrlBuilder } from '@sanity/image-url';
import { sanityClient } from 'sanity:client';
import { Icon } from 'astro-icon/components';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { DateTime, PortableText } from '~/components';
import { getPosts } from '~/sanity/queries';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

export type Props = Article;

const post = Astro.props as Article;
const heroImageHotspot = post.mainImage?.hotspot as
  | { x?: number; y?: number }
  | undefined;
const heroImagePosition =
  heroImageHotspot?.x != null && heroImageHotspot?.y != null
    ? `${heroImageHotspot.x * 100}% ${heroImageHotspot.y * 100}%`
    : '50% 50%';
const heroImageBuilder = createImageUrlBuilder(sanityClient)
  .fit('crop')
  .format('webp');
const heroImageWidths = [640, 960, 1280, 1600, 1920, 2400];
const heroImageHeightForWidth = (width: number) => Math.round(width / 2);
const heroImageSrc =
  post.mainImage &&
  heroImageBuilder
    .image(post.mainImage)
    .width(1600)
    .height(heroImageHeightForWidth(1600))
    .quality(78)
    .url();
const heroImageSrcSet =
  post.mainImage &&
  heroImageWidths
    .map((width) => {
      const url = heroImageBuilder
        .image(post.mainImage)
        .width(width)
        .height(heroImageHeightForWidth(width))
        .quality(78)
        .url();

      return `${url} ${width}w`;
    })
    .join(', ');
const heroImageAlt = post.mainImage?.asset.alt || post.title || '';
const postHeroMediaTransitionName = `post-hero-media-${post.slug}`;
const hasReadingTime =
  typeof post.readingTime === 'number' && post.readingTime > 0;
const countryNames = post.countries
  ?.map((country) => country.name)
  .filter(Boolean)
  .join(', ');
---

<BaseLayout
  meta={{
    title: `${post.title} | callum.co.uk`,
    description: post.excerpt,
    image:
      post.mainImage &&
      imageBuilder.image(post.mainImage).width(1600).height(900).url(),
  }}
>
  <article class="article-page">
    <header
      class="article-hero"
      data-has-image={heroImageSrc ? 'true' : 'false'}
    >
      {
        heroImageSrc && (
          <figure
            class="article-hero-media"
            style={`--article-hero-image-position: ${heroImagePosition};`}
            transition:name={postHeroMediaTransitionName}
            transition:animate="none"
          >
            <img
              class="article-hero-image"
              src={heroImageSrc}
              srcset={heroImageSrcSet}
              sizes="100vw"
              alt={heroImageAlt}
              width="1600"
              height={heroImageHeightForWidth(1600)}
              decoding="async"
              fetchpriority="high"
              loading="eager"
            />
            {post.mainImage?.alt && (
              <figcaption class="sr-only">{post.mainImage.alt}</figcaption>
            )}
          </figure>
        )
      }

      <div class="article-hero-overlay" aria-hidden="true"></div>

      <div class="article-hero-inner container max-w-6xl">
        <div class="article-hero-copy">
          {
            countryNames && (
              <p class="article-hero-countries" aria-label="Countries">
                <span class="article-hero-country">
                  <Icon
                    name="mdi:map-marker"
                    class="article-hero-country-icon"
                  />
                  <span>{countryNames}</span>
                </span>
              </p>
            )
          }

          <h1 class="article-hero-title">
            {post.title}
          </h1>

          {post?.excerpt && <p class="article-hero-excerpt">{post.excerpt}</p>}

          {
            (post?.publishedAt || hasReadingTime) && (
              <div class="article-hero-details" aria-label="Article details">
                {post?.publishedAt && (
                  <p class="article-hero-detail">
                    <Icon
                      name="mdi:calendar-blank-outline"
                      class="article-hero-detail-icon"
                    />
                    <span>
                      Published on <DateTime date={post.publishedAt} />
                    </span>
                  </p>
                )}

                {hasReadingTime && (
                  <p class="article-hero-detail">
                    <Icon
                      name="mdi:book-open-page-variant-outline"
                      class="article-hero-detail-icon"
                    />
                    <span>
                      Estimated <strong>{post.readingTime} min read</strong>
                    </span>
                  </p>
                )}
              </div>
            )
          }
        </div>
      </div>
    </header>

    <div class="article-content">
      <PortableText value={post.content} />
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    background:
      radial-gradient(
        circle at 88% 14%,
        color-mix(in srgb, var(--color-brand-medium) 18%, transparent),
        transparent 21rem
      ),
      var(--color-gray-950);
  }

  .article-hero {
    --hero-image-aspect-ratio: 2 / 1;

    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    overflow: hidden;
    background:
      radial-gradient(
        circle at 18% 22%,
        color-mix(in srgb, var(--color-brand-medium) 34%, transparent),
        transparent 25rem
      ),
      var(--color-gray-950);
  }

  .article-hero::before {
    display: block;
    grid-area: 1 / 1;
    width: 100%;
    aspect-ratio: var(--hero-image-aspect-ratio);
    content: '';
  }

  .article-hero-media,
  .article-hero-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .article-hero-media {
    z-index: -2;
    margin: 0;
    overflow: hidden;
    mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    mask-repeat: no-repeat;
    mask-size: 100% 100%;
    opacity: 0;
    transition: opacity 720ms ease;
    -webkit-mask-image: linear-gradient(
      180deg,
      rgb(0 0 0) 0%,
      rgb(0 0 0) calc(100% - 200px),
      rgb(0 0 0 / 0) 100%
    );
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
  }

  .article-hero-media[data-image-loaded='true'] {
    opacity: 0.8;
  }

  .article-hero-image {
    width: 100%;
    height: 100%;
    filter: brightness(0.56);
    object-fit: cover;
    object-position: var(--article-hero-image-position, 50% 50%);
  }

  .article-hero-overlay {
    z-index: -1;
    background: rgb(3 7 18 / 0.18);
  }

  .article-hero-inner {
    position: relative;
    grid-area: 1 / 1;
    display: flex;
    width: 100%;
    min-width: 0;
    align-items: flex-start;
    padding-block: 6rem 2.5rem;
  }

  .article-hero-copy {
    width: 100%;
    min-width: 0;
    max-width: 58rem;
  }

  .article-hero-countries {
    display: flex;
    width: fit-content;
    max-width: 100%;
    margin: 0 0 1.25rem;
    filter: url(#buttonFilter);
  }

  .article-hero-country {
    display: inline-flex;
    max-width: 100%;
    min-height: 1.9rem;
    align-items: center;
    gap: 0.28rem;
    border-radius: 999px;
    background: var(--color-brand-medium);
    padding-block: 0.42rem;
    padding-inline: 0.62rem 0.72rem;
    color: var(--color-gray-50);
    font-size: 0.75rem;
    font-weight: 750;
    line-height: 1.15;
  }

  .article-hero-country :global(.article-hero-country-icon) {
    width: 0.82rem;
    height: 0.82rem;
  }

  .article-hero-country span {
    min-width: 0;
  }

  .article-hero-title {
    max-width: 14ch;
    margin: 0;
    color: var(--color-gray-50);
    font-size: clamp(2.75rem, 6vw, 4.75rem);
    font-weight: 850;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .article-hero-excerpt {
    max-width: 42rem;
    margin: 1.35rem 0 0;
    color: var(--color-gray-200);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.62;
  }

  .article-hero-details {
    display: flex;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 1.15rem 0 0;
  }

  .article-hero-detail {
    display: inline-flex;
    max-width: 100%;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    border-radius: 999px;
    background: rgb(3 7 18 / 0.1);
    padding: 0.2rem 0.85rem 0.2rem 0.2rem;
    color: var(--color-gray-200);
    font-size: 0.9375rem;
    line-height: 1;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .article-hero-detail :global(.article-hero-detail-icon) {
    box-sizing: content-box;
    flex: 0 0 auto;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: var(--color-brand-medium);
    padding: 0.35rem;
    color: var(--color-gray-50);
  }

  .article-hero-detail :global(time),
  .article-hero-detail strong {
    font-weight: 700;
    letter-spacing: 0;
  }

  .article-hero-detail span {
    min-width: 0;
  }

  .article-content {
    padding-block: clamp(3rem, 7vw, 5rem) 1rem;
  }

  @media (width >= 64rem) {
    .article-hero-inner {
      padding-block: 8.75rem 2.5rem;
    }
  }

  @media (width < 48rem) {
    .article-hero-inner {
      padding-block: 5.75rem 2rem;
    }

    .article-hero-title {
      max-width: 11ch;
    }

    .article-hero-countries {
      filter: none;
    }
  }
</style>
