---
import { SEO } from 'astro-seo';
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';
import Logo from '~/components/Logo.astro';

import '../styles/global.css';

type meta = {
  title?: string;
  description?: string;
  image?: string;
};

export type Props = {
  meta?: meta;
};

const { meta } = Astro.props;

const title = meta?.title || 'Callum Bonnyman | callum.co.uk';
const description =
  meta?.description ||
  'Callum Bonnyman: Discovering offbeat travel destinations through my travel blog.';
const image = meta?.image || 'https://callum.co.uk/callum-social-image.webp';

const thisYear = new Date().getFullYear();
const isHomepage = Astro.url.pathname === '/';
const isArticlePage = Astro.url.pathname.startsWith('/article/');
const usesHeroHeader = isHomepage || isArticlePage;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: 'post',
          image,
        },
      }}
      twitter={{
        creator: '@wrux',
      }}
      extend={{
        meta: [
          {
            name: 'twitter:image',
            content: image,
          },
          { name: 'twitter:title', content: title },
          { name: 'twitter:description', content: description },
        ],
      }}
    />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="callum.co.uk" />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter fallback="swap" />
  </head>

  <body
    id="top"
    class="site-body"
    data-is-homepage={isHomepage}
    data-is-article-page={isArticlePage}
    data-uses-hero-header={usesHeroHeader}
  >
    <header
      class="site-header"
      data-is-homepage={isHomepage}
      data-is-article-page={isArticlePage}
      data-uses-hero-header={usesHeroHeader}
      data-is-stuck="false"
    >
      <div class="u-container u-container-6xl">
        <div class="site-header-shell">
          <div class="site-header-side site-header-side-start">
            {
              !isHomepage && (
                <a
                  href="/"
                  class="t-site-action btn btn-glass btn-header site-header-action site-header-action-back"
                  aria-label="Back to homepage"
                  transition:name="site-header-back"
                >
                  <Icon name="mdi:keyboard-backspace" />
                  <span>Back</span>
                </a>
              )
            }
          </div>

          {
            !isHomepage ? (
              <a
                class="site-header-logo-link"
                href="/"
                aria-label="Go to the homepage"
                transition:name="site-header-logo"
              >
                <span class="site-header-logo-surface" aria-hidden="true" />
                <Logo class="t-logo-md site-header-logo" />
              </a>
            ) : (
              <span class="site-header-logo-placeholder" aria-hidden="true" />
            )
          }

          <nav
            class="site-header-side site-header-side-end"
            aria-label="External navigation"
          >
            <a
              href="https://wrux.com"
              target="_blank"
              class="t-site-action btn btn-glass btn-header site-header-action site-header-action-external"
              aria-label="Visit wrux.com"
              rel="noreferrer"
            >
              <span>wrux.com</span>
              <Icon name="mdi:open-in-new" />
            </a>
          </nav>
        </div>
      </div>
    </header>

    <slot name="header" />

    <main class="site-main u-flex-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="u-container u-container-6xl">
        <div class="footer-brand">
          <Logo class="t-logo-xl footer-logo" />

          <nav aria-label="External links">
            <div class="footer-social-shell">
              <ul class="footer-social-list">
                <li>
                  <a
                    href="https://instagram.com/wrux"
                    target="_blank"
                    class="btn btn-primary btn-icon footer-social-link"
                    aria-label="View my Instagram profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:instagram" />
                  </a>
                </li>
                <li>
                  <a
                    href="https://github.com/wrux"
                    target="_blank"
                    class="btn btn-primary btn-icon footer-social-link"
                    aria-label="View my GitHub profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:github" />
                  </a>
                </li>
                <li>
                  <a
                    href="https://www.linkedin.com/in/wrux"
                    target="_blank"
                    class="btn btn-primary btn-icon footer-social-link"
                    aria-label="View my LinkedIn profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:linkedin" />
                  </a>
                </li>
              </ul>
            </div>
          </nav>
        </div>

        <div class="footer-bottom">
          <p class="t-footer footer-copyright">
            Copyright &copy;{' '}
            <a
              href="https://wrux.com"
              target="_blank"
              class="t-footer-link link"
              aria-label="View my professional profile at wrux.com"
              rel="noreferrer"
            >
              Callum Bonnyman
            </a>{' '}
            {thisYear}.
          </p>
          <a
            href="https://github.com/wrux/callum"
            target="_blank"
            class="t-footer-link footer-repo-link link"
            rel="noreferrer nofollow"
          >
            <span>Get the source code</span>
            <Icon name="mdi:open-in-new" class="footer-repo-link-icon" />
          </a>
        </div>
      </div>
    </footer>

    <a
      href="#top"
      class="btn btn-glass btn-icon-lg back-to-top-button"
      aria-label="Back to top"
    >
      <Icon name="mdi:arrow-up" />
    </a>

    <script is:inline>
      (() => {
        const chromeInitializedKey = '__callumChromeSyncInitialized';
        const imageInitializedKey = '__callumImageLoadStateInitialized';
        const viewTransitionInitializedKey =
          '__callumViewTransitionInitialized';

        function syncHeaderScrollState() {
          const header = document.querySelector('.site-header');

          if (header) {
            header.dataset.isStuck = String(window.scrollY > 0);
          }
        }

        function markHeroImageLoaded(image) {
          image.dataset.callumImageLoaded = 'true';
          image
            .closest('.media-hero-asset')
            ?.setAttribute('data-image-loaded', 'true');
        }

        function revealLqipImage(image, shouldAnimate) {
          if (image.dataset.callumImageLoaded === 'true') {
            image.style.opacity = '1';
            return;
          }

          image.dataset.callumImageLoaded = 'true';

          const prefersReducedMotion = window.matchMedia(
            '(prefers-reduced-motion: reduce)',
          ).matches;
          const duration = Number(image.dataset.xLqipTransitionDuration) || 0;

          if (
            shouldAnimate &&
            duration > 0 &&
            !prefersReducedMotion &&
            typeof image.animate === 'function'
          ) {
            const animation = image.animate([{ opacity: 0 }, { opacity: 1 }], {
              duration,
              fill: 'forwards',
            });

            animation.onfinish = () => {
              image.style.opacity = '1';
              animation.cancel();
            };

            return;
          }

          image.style.opacity = '1';
        }

        function syncImageLoadStates() {
          document
            .querySelectorAll('.media-hero-asset img')
            .forEach((image) => {
              if (!(image instanceof HTMLImageElement)) {
                return;
              }

              if (image.complete && image.naturalWidth > 0) {
                markHeroImageLoaded(image);
                return;
              }

              if (image.dataset.callumLoadListenerAttached === 'true') {
                return;
              }

              image.dataset.callumLoadListenerAttached = 'true';
              image.addEventListener(
                'load',
                () => {
                  requestAnimationFrame(() => {
                    markHeroImageLoaded(image);
                  });
                },
                { once: true },
              );
            });

          document
            .querySelectorAll('img[data-x-lqip="true"]')
            .forEach((image) => {
              if (!(image instanceof HTMLImageElement)) {
                return;
              }

              if (image.complete && image.naturalWidth > 0) {
                revealLqipImage(image, false);
                return;
              }

              if (image.dataset.callumLoadListenerAttached === 'true') {
                return;
              }

              image.dataset.callumLoadListenerAttached = 'true';
              image.addEventListener(
                'load',
                () => {
                  revealLqipImage(image, true);
                },
                { once: true },
              );
            });
        }

        function waitForImageLoad(image) {
          return new Promise((resolve) => {
            let isSettled = false;
            const timeout = window.setTimeout(() => finish(false), 1200);

            function finish(didLoad) {
              if (isSettled) {
                return;
              }

              isSettled = true;
              window.clearTimeout(timeout);
              resolve(didLoad);
            }

            image.addEventListener('load', () => finish(true), { once: true });
            image.addEventListener('error', () => finish(false), {
              once: true,
            });

            if (image.complete) {
              finish(image.naturalWidth > 0);
            }
          });
        }

        async function preloadDocumentHeroImage(newDocument) {
          const source = newDocument?.querySelector?.('.media-hero-image[src]');

          if (!(source instanceof HTMLImageElement)) {
            return;
          }

          const image = new Image();
          image.decoding = 'async';

          if ('fetchPriority' in image) {
            image.fetchPriority = 'high';
          }

          if (source.sizes) {
            image.sizes = source.sizes;
          }

          if (source.srcset) {
            image.srcset = source.srcset;
          }

          image.src = source.currentSrc || source.src;
          const didLoad = await waitForImageLoad(image);

          if (didLoad && typeof image.decode === 'function') {
            await image.decode().catch(() => {});
          }
        }

        function preloadHeroImageBeforeSwap(event) {
          if (typeof event.loader !== 'function') {
            return;
          }

          const loadPage = event.loader;

          event.loader = async () => {
            await loadPage();
            await preloadDocumentHeroImage(event.newDocument);
          };
        }

        syncHeaderScrollState();
        syncImageLoadStates();
        if (!window[chromeInitializedKey]) {
          window[chromeInitializedKey] = true;
          document.addEventListener('astro:page-load', syncHeaderScrollState);
          document.addEventListener('astro:after-swap', syncHeaderScrollState);
          window.addEventListener('scroll', syncHeaderScrollState, {
            passive: true,
          });
        }

        if (!window[imageInitializedKey]) {
          window[imageInitializedKey] = true;
          document.addEventListener('astro:after-swap', syncImageLoadStates);
          document.addEventListener('astro:page-load', syncImageLoadStates);
          window.addEventListener('pageshow', syncImageLoadStates);
        }

        if (!window[viewTransitionInitializedKey]) {
          window[viewTransitionInitializedKey] = true;
          document.addEventListener(
            'astro:before-preparation',
            preloadHeroImageBeforeSwap,
          );
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  .site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 50;
    background: rgb(3 7 18 / 0.78);
    transition: background 220ms ease;
  }

  .site-body {
    background: var(--color-gray-950);
    color: var(--color-gray-50);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .site-header[data-uses-hero-header='true'] {
    background: transparent;
  }

  .site-header[data-is-stuck='true'] {
    background: rgb(3 7 18 / 0.78);
  }

  .site-main {
    padding-block-start: 4.75rem;
  }

  body[data-uses-hero-header='true'] .site-main {
    padding-block-start: 0;
  }

  .site-header-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(0.4rem, 2vw, 1rem);
    min-height: 4.75rem;
  }

  .site-header-side {
    display: flex;
    min-width: 0;
    align-items: center;
  }

  .site-header-side-start {
    justify-content: flex-start;
  }

  .site-header-side-end {
    justify-content: flex-end;
  }

  .site-header-logo-link,
  .site-header-logo-placeholder {
    position: relative;
    isolation: isolate;
    display: grid;
    width: 3.5rem;
    aspect-ratio: 1;
    place-items: center;
  }

  .site-header-logo-link {
    color: var(--color-gray-50);
    text-decoration: none;
  }

  .site-header-logo-link:focus {
    outline: none;
  }

  .site-header-logo-surface {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 999px;
    background: hsl(225 80% 50%);
    opacity: 0;
    transform: scale(0.72);
    transition:
      opacity 260ms ease,
      transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-header-logo {
    color: currentColor;
    position: relative;
    z-index: 1;
    transition:
      color 220ms ease,
      filter 200ms ease,
      transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-header-logo-link:hover,
  .site-header-logo-link:focus-visible {
    color: var(--color-gray-50);
  }

  .site-header-logo-link:hover .site-header-logo-surface,
  .site-header-logo-link:focus-visible .site-header-logo-surface {
    opacity: 1;
    transform: scale(1);
  }

  .site-header-logo-link:hover .site-header-logo,
  .site-header-logo-link:focus-visible .site-header-logo {
    filter: brightness(0) invert(1);
    transform: scale(0.9);
  }

  .back-to-top-button {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .back-to-top-button:is(:hover, :focus-visible) {
    transform: translateY(-0.12rem);
  }

  @keyframes back-to-top-reveal {
    from {
      opacity: 0;
      pointer-events: none;
      visibility: hidden;
    }

    to {
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
    }
  }

  @supports (animation-timeline: scroll()) {
    .back-to-top-button {
      opacity: 0;
      pointer-events: none;
      visibility: hidden;
      animation: back-to-top-reveal linear both;
      animation-timeline: scroll(root block);
      animation-range: 24rem 32rem;
    }
  }

  @media (width < 36rem) {
    .site-main {
      padding-block-start: 4.25rem;
    }

    .site-header-shell {
      min-height: 4.25rem;
    }

    .site-header-logo-link {
      width: 3.1rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }

  .footer-logo {
    opacity: 0.9;
  }

  .site-footer {
    margin-top: 2rem;
    padding-block: clamp(2.5rem, 1.25rem + 2.6vw, 3.5rem);
    border-top: 1px solid oklch(27.8% 0.033 256.848);
    background: oklch(13% 0.028 261.692);
  }

  .footer-copyright {
    margin: 0;
    color: var(--color-gray-200);
    text-align: left;
  }

  .footer-copyright .link {
    color: var(--color-gray-200);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-start: 3rem;
    border-top: 1px solid var(--color-gray-800);
    padding-block-start: 1rem;
  }

  .footer-repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex: none;
    color: var(--color-gray-100);
    text-align: right;
    white-space: nowrap;
  }

  .footer-repo-link .footer-repo-link-icon {
    flex: 0 0 auto;
    width: 0.85rem;
    height: 0.85rem;
  }
</style>
