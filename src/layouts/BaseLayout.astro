---
import { SEO } from 'astro-seo';
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';
import { Logo } from '~/components';

import '../styles/link.css';
import '../styles/global.css';

type meta = {
  title?: string;
  description?: string;
  image?: string;
};

export type Props = {
  meta?: meta;
};

const { meta } = Astro.props;

const title = meta?.title || 'Callum Bonnyman | callum.co.uk';
const description =
  meta?.description ||
  'Callum Bonnyman: Discovering offbeat travel destinations through my travel blog.';
const image = meta?.image || 'https://callum.co.uk/callum-social-image.webp';

const thisYear = new Date().getFullYear();
const isHomepage = Astro.url.pathname === '/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: 'post',
          image,
        },
      }}
      twitter={{
        creator: '@wrux',
      }}
      extend={{
        meta: [
          {
            name: 'twitter:image',
            content: image,
          },
          { name: 'twitter:title', content: title },
          { name: 'twitter:description', content: description },
        ],
      }}
    />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="callum.co.uk" />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />
  </head>

  <body
    class="bg-gray-950 text-gray-50 antialiased"
    data-is-homepage={isHomepage}
  >
    <header
      class="site-header sticky top-0 z-50 border-b border-transparent bg-gray-950/85 backdrop-blur-xl transition-colors duration-200 data-[is-stuck=true]:border-gray-800"
      data-is-homepage={isHomepage}
      data-is-stuck="false"
      transition:name="site-header"
      transition:persist
    >
      <div
        class="container flex h-16 max-w-6xl items-center justify-between gap-4"
      >
        <a
          class="group hover:text-brand-light flex size-12 shrink-0 items-center justify-center text-gray-50 transition-colors duration-200"
          href="/"
          aria-label="Go to the homepage"
        >
          <Logo class="text-[2.25rem] md:text-[2.4rem]" />
        </a>

        <nav
          class="flex min-w-0 items-center justify-end gap-2 text-sm font-medium text-gray-300"
          aria-label="Primary navigation"
        >
          <a
            href="/"
            class="header-back-link inline-flex h-9 items-center gap-1.5 rounded-md px-2.5 transition-colors duration-200 hover:bg-white/10 hover:text-gray-50"
            aria-label="Back to homepage"
            aria-hidden={isHomepage ? 'true' : 'false'}
            data-header-back-link
            hidden={isHomepage}
          >
            <Icon name="mdi:keyboard-backspace" class="h-4 w-4" />
            <span>Back</span>
          </a>

          <a
            href="https://wrux.com"
            target="_blank"
            class="inline-flex h-9 items-center gap-1.5 rounded-md px-2.5 transition-colors duration-200 hover:bg-white/10 hover:text-gray-50"
            aria-label="Visit wrux.com"
            rel="noreferrer"
          >
            <span>wrux.com</span>
            <Icon name="mdi:open-in-new" class="h-3.5 w-3.5" />
          </a>
        </nav>
      </div>
    </header>

    <slot name="header" />

    <main class="flex-1">
      <slot />
    </main>

    <footer
      class="mt-8 border-t border-gray-800 bg-gray-950 py-12 md:py-16 lg:py-20"
    >
      <div class="container max-w-6xl space-y-10 md:space-y-16">
        <div
          class="grid grid-cols-1 items-start gap-x-16 gap-y-8 md:grid-cols-4"
        >
          <div class="col-span-1">
            <Logo class="text-[5rem] opacity-90 md:text-[6rem]" />
          </div>

          <div class="col-span-1">
            <p class="type-h6 mb-4 font-semibold text-gray-100">Links</p>
            <nav aria-label="External links" class="flex gap-2">
              <ul class="flex gap-3 text-3xl md:text-4xl">
                <li>
                  <a
                    href="https://instagram.com/wrux"
                    target="_blank"
                    class="link hover:text-brand-light transition-all duration-200 hover:scale-110"
                    aria-label="View my Instagram profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:instagram" class="h-[1em] w-[1em]" />
                  </a>
                </li>
                <li>
                  <a
                    href="https://github.com/wrux"
                    target="_blank"
                    class="link hover:text-brand-light transition-all duration-200 hover:scale-110"
                    aria-label="View my Github profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:github" class="h-[1em] w-[1em]" />
                  </a>
                </li>
                <li>
                  <a
                    href="https://www.linkedin.com/in/wrux"
                    target="_blank"
                    class="link hover:text-brand-light transition-all duration-200 hover:scale-110"
                    aria-label="View my Linkedin profile"
                    rel="noreferrer nofollow"
                  >
                    <Icon name="mdi:linkedin" class="h-[1em] w-[1em]" />
                  </a>
                </li>
              </ul>
            </nav>
          </div>

          <div class="col-span-1 md:col-span-2">
            <p class="type-h6 mb-3 font-semibold text-gray-100">
              Like this website?
            </p>
            <p class="type-text-sm text-gray-400">
              If you like this website,{' '}
              <a
                href="https://github.com/wrux/bloke"
                target="_blank"
                class="link font-medium"
                rel="noreferrer nofollow"
              >
                view the source code
              </a>
              , fork the project and take whatever you like.
            </p>
          </div>
        </div>

        <p
          class="type-text-sm border-t border-gray-800 pt-8 text-center text-gray-400"
        >
          Copyright &copy;{' '}
          <a
            href="https://wrux.com"
            target="_blank"
            class="link font-medium"
            aria-label="View my professional profile at wrux.com"
            rel="noreferrer"
          >
            Callum Bonnyman
          </a>{' '}
          {thisYear}.
        </p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const initializedKey = '__callumHeaderSyncInitialized';

        function syncHeaderState() {
          const header = document.querySelector('.site-header');
          const backLink = document.querySelector('[data-header-back-link]');
          const isHomepage = window.location.pathname === '/';

          if (header) {
            header.dataset.isHomepage = String(isHomepage);
            header.dataset.isStuck = String(window.scrollY > 0);
          }

          if (backLink) {
            backLink.hidden = isHomepage;
            backLink.setAttribute('aria-hidden', String(isHomepage));
            if (isHomepage) {
              backLink.setAttribute('tabindex', '-1');
            } else {
              backLink.removeAttribute('tabindex');
            }
          }
        }

        syncHeaderState();

        if (!window[initializedKey]) {
          window[initializedKey] = true;
          document.addEventListener('astro:page-load', syncHeaderState);
          document.addEventListener('astro:after-swap', syncHeaderState);
          window.addEventListener('scroll', syncHeaderState, { passive: true });
        }
      })();
    </script>
  </body>
</html>
