---

export type Props = {
  date: string;
};

const { date } = Astro.props;

const dateObject = new Date(date);
const dateIso = dateObject.toISOString();
const dateString = dateObject.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<time class="t-meta-emphasis" datetime={dateIso}>
  {dateString}
</time>
