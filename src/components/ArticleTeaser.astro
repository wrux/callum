---
import { Icon } from 'astro-icon/components';
import SanityPicture from 'astro-sanity-picture';
import BubbleArrowSurface from '~/components/BubbleArrowSurface.astro';
import { imageBuilder } from '~/sanity/image';

export type Props = ArticleTeaser & {
  lazy?: boolean | number;
  priority?: boolean;
  sizes?: string;
};

const {
  excerpt,
  lazy = false,
  mainImage,
  priority = false,
  readingTime,
  sizes = '(max-width: 767px) calc(100vw - 2rem), (max-width: 1023px) calc((100vw - 3rem) * 0.5), (max-width: 1535px) calc((100vw - 4rem) * 0.33), 28rem',
  slug,
  title,
} = Astro.props;

const loading = lazy ? 'lazy' : 'eager';
const hasReadingTime = typeof readingTime === 'number' && readingTime > 0;
---

<article class="article-teaser u-relative u-flex u-min-0 u-flex-col">
  {
    mainImage && (
      <figure class="article-teaser-figure">
        <div class="media-frame article-teaser-frame u-relative">
          <SanityPicture
            class="u-h-full u-full"
            src={mainImage}
            imageUrlBuilder={imageBuilder}
            sizes={sizes}
            widths={[320, 480, 640, 800, 960]}
            sources={[{ options: { quality: 74 } }]}
            img={{
              alt: mainImage.asset.alt || title || '',
              class: 'article-teaser-image u-h-full u-full u-object-cover',
              decoding: 'async',
              fetchpriority: priority ? 'high' : 'auto',
              loading,
            }}
          />
        </div>
      </figure>
    )
  }
  <div class="article-teaser-body u-flex u-flex-1 u-flex-col">
    {
      hasReadingTime && (
        <p class="t-card-meta u-text-muted u-mt-0 u-mb-2">
          {readingTime} min read
        </p>
      )
    }
    <h2 class="t-h3 article-teaser-title u-mt-0 u-mb-2 u-text-left">
      {title}
    </h2>
    {
      excerpt && (
        <p class="t-card-summary article-teaser-summary u-m-0 u-text-left u-text-muted">
          {excerpt}
        </p>
      )
    }
    <div class="article-teaser-action">
      <a
        class="t-action article-card-link"
        href={`/article/${slug}`}
        title={`Read article ${title}`}
        aria-label={`Read article ${title}`}
      >
        <span class="bubble-arrow-link">
          <BubbleArrowSurface />
          Read article
          <Icon
            name="mdi:arrow-top-right"
            class="bubble-arrow-link__icon"
            aria-hidden="true"
          />
        </span>
      </a>
    </div>
  </div>
</article>

<style>
  .article-teaser-title {
    transition: color 300ms ease;
  }

  .article-teaser-figure {
    margin: 0;
    overflow: hidden;
  }

  .article-teaser-frame {
    aspect-ratio: 16 / 9;
  }

  .article-teaser-body {
    padding-top: 1rem;
  }

  .article-teaser-action {
    margin-top: auto;
    padding-top: 1rem;
  }

  .article-teaser-summary {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .article-teaser:hover .article-teaser-title,
  .article-teaser:focus-within .article-teaser-title {
    color: hsl(225 80% 70%);
  }

  .article-teaser :global(.article-teaser-image) {
    transition: transform 700ms cubic-bezier(0, 0, 0.2, 1);
  }

  .article-teaser:hover :global(.article-teaser-image) {
    transform: scale(1.05);
  }
</style>
