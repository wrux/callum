---
import { Icon } from 'astro-icon/components';
import SanityPicture from 'astro-sanity-picture';
import BubbleArrowSurface from '~/components/BubbleArrowSurface.astro';
import { imageBuilder } from '~/sanity/image';
import { typeStyle } from '~/utils/typography';

export type Props = ArticleTeaser & {
  lazy?: boolean | number;
  priority?: boolean;
  sizes?: string;
};

const {
  excerpt,
  lazy = false,
  mainImage,
  priority = false,
  readingTime,
  sizes = '(max-width: 767px) calc(100vw - 2rem), (max-width: 1023px) calc((100vw - 3rem) * 0.5), (max-width: 1535px) calc((100vw - 4rem) * 0.33), 28rem',
  slug,
  title,
} = Astro.props;

const loading = lazy ? 'lazy' : 'eager';
const hasReadingTime = typeof readingTime === 'number' && readingTime > 0;
---

<article class="article-teaser group relative flex min-w-0 flex-col">
  {
    mainImage && (
      <figure class="m-0 overflow-hidden">
        <div class="media-frame relative aspect-video">
          <SanityPicture
            class="h-full w-full"
            src={mainImage}
            imageUrlBuilder={imageBuilder}
            sizes={sizes}
            widths={[320, 480, 640, 800, 960]}
            sources={[{ options: { quality: 74 } }]}
            img={{
              alt: mainImage.asset.alt || title || '',
              class: 'article-teaser-image h-full w-full object-cover',
              decoding: 'async',
              fetchpriority: priority ? 'high' : 'auto',
              loading,
            }}
          />
        </div>
      </figure>
    )
  }
  <div class="flex flex-1 flex-col pt-4">
    {
      hasReadingTime && (
        <p
          class:list={[
            typeStyle({ variant: 'cardMeta', tone: 'muted' }),
            'mt-0 mb-2',
          ]}
        >
          {readingTime} min read
        </p>
      )
    }
    <h2
      class:list={[
        typeStyle({ variant: 'h3' }),
        'article-teaser-title mt-0 mb-2 text-left',
      ]}
    >
      {title}
    </h2>
    {
      excerpt && (
        <p
          class:list={[
            typeStyle({ variant: 'cardSummary' }),
            'article-teaser-summary m-0 text-left text-gray-400',
          ]}
        >
          {excerpt}
        </p>
      )
    }
    <div class="mt-auto pt-4">
      <a
        class:list={[typeStyle({ variant: 'action' }), 'article-card-link']}
        href={`/article/${slug}`}
        title={`Read article ${title}`}
        aria-label={`Read article ${title}`}
      >
        <span class="bubble-arrow-link">
          <BubbleArrowSurface />
          Read article
          <Icon
            name="mdi:arrow-top-right"
            class="bubble-arrow-link__icon"
            aria-hidden="true"
          />
        </span>
      </a>
    </div>
  </div>
</article>

<style>
  .article-teaser-title {
    transition: color 300ms ease;
  }

  .article-teaser-summary {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .article-teaser:hover .article-teaser-title,
  .article-teaser:focus-within .article-teaser-title {
    color: hsl(225 80% 70%);
  }

  .article-teaser :global(.article-teaser-image) {
    transition: transform 700ms cubic-bezier(0, 0, 0.2, 1);
  }

  .article-teaser:hover :global(.article-teaser-image) {
    transform: scale(1.05);
  }
</style>
