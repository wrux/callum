---
import { Icon } from 'astro-icon/components';
import SanityPicture from 'astro-sanity-picture';
import { imageBuilder } from '~/sanity/image';

export type Props = ArticleTeaser & {
  lazy?: boolean | number;
  priority?: boolean;
  sizes?: string;
};

const {
  excerpt,
  imageCount,
  lazy = false,
  mainImage,
  priority = false,
  readingTime,
  sizes = '(max-width: 767px) calc(100vw - 2rem), (max-width: 1023px) calc((100vw - 3rem) * 0.5), (max-width: 1535px) calc((100vw - 4rem) * 0.33), 28rem',
  slug,
  title,
} = Astro.props;

const loading = lazy ? 'lazy' : 'eager';
---

<article
  class="link-box group flex flex-col overflow-hidden rounded-2xl border border-gray-800/50 bg-gray-900 shadow-md transition-all duration-500 hover:border-gray-700 hover:shadow-2xl"
>
  {
    mainImage && (
      <figure class="relative w-full overflow-hidden">
        <div class="relative aspect-[16/9] overflow-hidden">
          <SanityPicture
            src={mainImage}
            imageUrlBuilder={imageBuilder}
            sizes={sizes}
            widths={[320, 480, 640, 800, 960]}
            sources={[{ options: { quality: 74 } }]}
            img={{
              alt: mainImage.asset.alt || title || '',
              class:
                'transition-transform duration-700 ease-out group-hover:scale-110 w-full h-full object-cover',
              decoding: 'async',
              fetchpriority: priority ? 'high' : 'auto',
              loading,
            }}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
        </div>
      </figure>
    )
  }
  <div class="flex flex-grow flex-col p-5 md:p-6 lg:p-8">
    {
      (imageCount || readingTime) && (
        <p class="type-text-xs type-text-muted mb-2 font-medium tracking-wider uppercase">
          {[
            readingTime && `${readingTime} min read`,
            imageCount && `${imageCount} image${imageCount > 1 ? 's' : ''}`,
          ]
            .filter(Boolean)
            .join(' • ')}
        </p>
      )
    }
    <h2
      class="type-h3 group-hover:text-brand-light mb-2 text-left transition-colors duration-300"
    >
      {title}
    </h2>
    {
      excerpt && (
        <p class="type-text-sm mb-3 line-clamp-3 text-left leading-relaxed text-gray-400">
          {excerpt}
        </p>
      )
    }
    <div class="mt-auto">
      <a
        class="link link-overlay group/link inline-flex items-center gap-1.5 text-sm font-medium"
        href={`/article/${slug}`}
        title={`Read article: ${title}`}
        aria-label={`Read article: ${title}`}
      >
        <span>Read article</span>
        <Icon
          name="mdi:chevron-right"
          class="inline-block h-5 w-5 transition-transform duration-500 group-hover/link:translate-x-1"
        />
      </a>
    </div>
  </div>
</article>
