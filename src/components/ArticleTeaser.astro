---
import { Icon } from 'astro-icon/components';
import SanityPicture from 'astro-sanity-picture';
import { imageBuilder } from '~/sanity/image';

export type Props = ArticleTeaser & {
  lazy?: boolean | number;
  priority?: boolean;
  sizes?: string;
};

const {
  excerpt,
  lazy = false,
  mainImage,
  priority = false,
  readingTime,
  sizes = '(max-width: 767px) calc(100vw - 2rem), (max-width: 1023px) calc((100vw - 3rem) * 0.5), (max-width: 1535px) calc((100vw - 4rem) * 0.33), 28rem',
  slug,
  title,
} = Astro.props;

const loading = lazy ? 'lazy' : 'eager';
const hasReadingTime = typeof readingTime === 'number' && readingTime > 0;
---

<article class="article-teaser group relative flex min-w-0 flex-col">
  {
    mainImage && (
      <figure class="m-0 overflow-hidden">
        <div class="media-frame relative aspect-video">
          <SanityPicture
            class="h-full w-full"
            src={mainImage}
            imageUrlBuilder={imageBuilder}
            sizes={sizes}
            widths={[320, 480, 640, 800, 960]}
            sources={[{ options: { quality: 74 } }]}
            img={{
              alt: mainImage.asset.alt || title || '',
              class:
                'h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105',
              decoding: 'async',
              fetchpriority: priority ? 'high' : 'auto',
              loading,
            }}
          />
        </div>
      </figure>
    )
  }
  <div class="flex flex-1 flex-col pt-4 md:pt-5">
    {
      hasReadingTime && (
        <p class="type-card-meta type-text-muted mt-0 mb-2">
          {readingTime} min read
        </p>
      )
    }
    <h2 class="type-h3 mt-0 mb-2 text-left transition-colors duration-300 group-hover:text-brand-light group-focus-within:text-brand-light">
      {title}
    </h2>
    {
      excerpt && (
        <p class="type-card-summary m-0 line-clamp-3 overflow-hidden text-left text-gray-400">
          {excerpt}
        </p>
      )
    }
    <div class="mt-auto pt-5">
      <a
        class="type-action article-card-link"
        href={`/article/${slug}`}
        title={`Read article ${title}`}
        aria-label={`Read article ${title}`}
      >
        <span class="bubble-arrow-link">
          <span class="bubble-arrow-link__surface" aria-hidden="true"></span>
          Read article
          <Icon
            name="mdi:arrow-top-right"
            class="bubble-arrow-link__icon"
            aria-hidden="true"
          />
        </span>
      </a>
    </div>
  </div>
</article>
