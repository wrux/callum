---
import Section from './Section.astro';
---

<div class="teaser-grid u-container u-container-screen-2xl">
  <slot />
</div>

<style>
  .teaser-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    row-gap: 5rem;
    column-gap: 1.5rem;

    @media (width >= 48rem) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (width >= 64rem) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
