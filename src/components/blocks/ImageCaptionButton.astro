---
export interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

{
  caption && (
    <figcaption class="t-caption surface-glass image-caption-overlay">
      {caption}
    </figcaption>
  )
}

<style is:global>
  .image-caption-overlay {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    z-index: 2;
    max-width: calc(100% - 1rem);
    margin: 0;
    padding: 0.375rem 0.5rem;
    color: var(--color-gray-50);
    border-radius: 0.5rem;
  }
</style>
