---
import { Icon } from 'astro-icon/components';
import { typeStyle } from '~/utils/typography';

export interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

{
  caption && (
    <details class="image-caption-popover">
      <summary class="image-caption-trigger" aria-label="Show image caption">
        <Icon
          name="mdi:information-outline"
          class="image-caption-icon"
          aria-hidden="true"
        />
      </summary>
      <p
        class:list={[typeStyle({ variant: 'caption' }), 'image-caption-panel']}
      >
        {caption}
      </p>
    </details>
  )
}

<script>
  const initImageCaptions = () => {
    document
      .querySelectorAll<HTMLDetailsElement>('.image-caption-popover')
      .forEach((popover) => {
        if (popover.dataset.captionReady) {
          return;
        }

        popover.dataset.captionReady = 'true';
      });
  };

  const closeInactiveImageCaptions = (target: EventTarget | null) => {
    document
      .querySelectorAll<HTMLDetailsElement>('.image-caption-popover[open]')
      .forEach((popover) => {
        if (target instanceof Node && popover.contains(target)) {
          return;
        }

        popover.open = false;
      });
  };

  const registerImageCaptionEvents = () => {
    const windowWithCaptionEvents = window as Window & {
      imageCaptionEventsReady?: boolean;
    };

    if (windowWithCaptionEvents.imageCaptionEventsReady) {
      return;
    }

    document.addEventListener('pointerdown', (event) => {
      closeInactiveImageCaptions(event.target);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeInactiveImageCaptions(null);
      }
    });

    document.addEventListener('astro:before-swap', () => {
      closeInactiveImageCaptions(null);
    });

    document.addEventListener('astro:after-swap', initImageCaptions);
    windowWithCaptionEvents.imageCaptionEventsReady = true;
  };

  registerImageCaptionEvents();
  initImageCaptions();
</script>

<style is:global>
  .image-caption-popover {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    z-index: 10;
  }

  .image-caption-trigger {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    list-style: none;
    cursor: pointer;
    color: var(--color-gray-50);
    background-color: rgb(3 7 18 / 0.35);
    border: 1px solid rgb(255 255 255 / 0.15);
    border-radius: 999px;
    box-shadow: 0 0.75rem 1.5rem rgb(4 13 18 / 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: background-color 0.2s ease;
  }

  .image-caption-trigger:hover,
  .image-caption-trigger:focus-visible {
    background-color: rgb(3 7 18 / 0.6);
  }

  .image-caption-trigger:focus-visible {
    outline: 2px solid hsl(225 80% 70%);
    outline-offset: 2px;
  }

  .image-caption-trigger::-webkit-details-marker {
    display: none;
  }

  .image-caption-trigger::marker {
    content: '';
  }

  .image-caption-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .image-caption-panel {
    position: absolute;
    right: 0;
    bottom: 2.75rem;
    z-index: 10;
    width: 18rem;
    max-width: calc(100vw - 1.5rem);
    max-height: 11rem;
    margin: 0;
    padding: 0.75rem;
    overflow: auto;
    color: var(--color-gray-100);
    background: transparent;
    border: 1px solid rgb(255 255 255 / 0.15);
    border-radius: var(--radius-lg);
    box-shadow: 0 1rem 2rem rgb(4 13 18 / 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .image-caption-popover[open] .image-caption-trigger {
    color: var(--color-gray-50);
    background-color: hsl(225 80% 50%);
  }
</style>
