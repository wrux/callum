---
import SanityPicture from 'astro-sanity-picture';
import Section from '../Section.astro';
import { imageBuilder } from '~/sanity/image';
import ImageCaptionButton from './ImageCaptionButton.astro';

export interface Props {
  node: {
    _key?: string;
    images: {
      caption: string;
      image: ImageWithMeta;
    }[];
  };
}

const { images } = Astro.props.node;
const galleryId = `gallery-${Astro.props.node._key ?? Math.random().toString(36).slice(2, 8)}`;
---

<Section width="mobile-full" data-block="image-gallery">
  <div class="article-gallery" data-gallery>
    <div class="gallery-desktop">
      {
        images.map(({ caption, image }) => (
          <figure class="gallery-item article-image-frame u-relative">
            <SanityPicture
              src={image}
              imageUrlBuilder={imageBuilder}
              style={{
                width: '100%',
                height: 'auto',
              }}
              sizes="(max-width: 1279px) calc(50vw - 3rem), 420px"
              widths={[320, 480, 640, 800, 960]}
              sources={[{ options: { quality: 74 } }]}
              img={{
                alt: image.asset.alt || caption || '',
                class: 'u-full',
                decoding: 'async',
                loading: 'lazy',
              }}
            />
            <ImageCaptionButton caption={caption} />
          </figure>
        ))
      }
    </div>

    {
      images.length > 0 && (
        <div class="gallery-mobile">
          <div class="gallery-track" data-gallery-track>
            {images.map(({ caption, image }, index) => {
              const slideId = `${galleryId}-slide-${index}`;

              return (
                <figure
                  class="gallery-slide article-image-frame u-relative"
                  id={slideId}
                  data-gallery-slide
                >
                  <SanityPicture
                    src={image}
                    imageUrlBuilder={imageBuilder}
                    style={{
                      width: '100%',
                      height: 'auto',
                    }}
                    sizes="100vw"
                    widths={[480, 640, 800, 960, 1280]}
                    sources={[{ options: { quality: 76 } }]}
                    img={{
                      alt: image.asset.alt || caption || '',
                      class: 'u-full',
                      decoding: 'async',
                      fetchpriority: index === 0 ? 'high' : 'auto',
                      loading: index === 0 ? 'eager' : 'lazy',
                    }}
                  />
                  <ImageCaptionButton caption={caption} />
                </figure>
              );
            })}
          </div>

          {images.length > 1 && (
            <div class="gallery-thumbs" aria-label="Gallery thumbnails">
              {images.map(({ image, caption }, index) => (
                <button
                  class="gallery-thumbnail"
                  type="button"
                  aria-label={`Show image ${index + 1}`}
                  aria-current={index === 0 ? 'true' : 'false'}
                  data-gallery-thumb
                  data-target-id={`${galleryId}-slide-${index}`}
                >
                  <SanityPicture
                    src={image}
                    imageUrlBuilder={imageBuilder}
                    style={{
                      width: '100%',
                      height: '100%',
                      objectFit: 'cover',
                    }}
                    sizes="72px"
                    widths={[72, 144]}
                    sources={[{ options: { quality: 70 } }]}
                    img={{
                      alt: image.asset.alt || caption || '',
                      class: 'u-full u-h-full u-object-cover',
                      decoding: 'async',
                      loading: 'lazy',
                    }}
                  />
                </button>
              ))}
            </div>
          )}
        </div>
      )
    }
  </div>
</Section>

<script>
  const syncScrollGalleries = () => {
    document.querySelectorAll('[data-gallery]').forEach((gallery) => {
      if (!(gallery instanceof HTMLElement)) {
        return;
      }

      if (gallery.dataset.snapReady === 'true') {
        return;
      }

      const track = gallery.querySelector('[data-gallery-track]');
      const slides = Array.from(
        gallery.querySelectorAll('[data-gallery-slide]'),
      );
      const thumbs = Array.from(
        gallery.querySelectorAll('[data-gallery-thumb]'),
      );

      if (!(track instanceof HTMLElement) || slides.length === 0) {
        return;
      }

      gallery.dataset.snapReady = 'true';

      const syncActiveThumb = () => {
        const trackCenter = track.scrollLeft + track.clientWidth / 2;
        let activeIndex = 0;
        let activeDistance = Number.POSITIVE_INFINITY;

        slides.forEach((slide, index) => {
          if (!(slide instanceof HTMLElement)) {
            return;
          }

          const slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
          const distance = Math.abs(trackCenter - slideCenter);

          if (distance < activeDistance) {
            activeDistance = distance;
            activeIndex = index;
          }
        });

        thumbs.forEach((thumb, index) => {
          if (!(thumb instanceof HTMLElement)) {
            return;
          }

          thumb.setAttribute('aria-current', String(index === activeIndex));
        });
      };

      let frame = 0;
      const requestSync = () => {
        window.cancelAnimationFrame(frame);
        frame = window.requestAnimationFrame(syncActiveThumb);
      };

      thumbs.forEach((thumb) => {
        if (!(thumb instanceof HTMLElement)) {
          return;
        }

        thumb.addEventListener('click', () => {
          const targetId = thumb.dataset.targetId;
          const target = targetId ? document.getElementById(targetId) : null;

          if (!(target instanceof HTMLElement)) {
            return;
          }

          target.scrollIntoView({
            behavior: window.matchMedia('(prefers-reduced-motion: reduce)')
              .matches
              ? 'auto'
              : 'smooth',
            block: 'nearest',
            inline: 'center',
          });
        });
      });

      track.addEventListener('scroll', requestSync, { passive: true });
      window.addEventListener('resize', requestSync, { passive: true });
      syncActiveThumb();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', syncScrollGalleries);
  } else {
    syncScrollGalleries();
  }

  document.addEventListener('astro:after-swap', syncScrollGalleries);
</script>

<style is:global>
  .article-gallery .gallery-desktop {
    display: none;
  }

  .article-gallery .gallery-mobile {
    display: grid;
    gap: 0.75rem;
  }

  .article-gallery .gallery-track {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-padding-inline: 1rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .article-gallery .gallery-track::-webkit-scrollbar {
    display: none;
  }

  .article-gallery .gallery-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
  }

  .article-gallery .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-inline: 1rem;
    scrollbar-width: none;
  }

  .article-gallery .gallery-thumbs::-webkit-scrollbar {
    display: none;
  }

  .article-gallery .gallery-thumbnail {
    display: block;
    flex: 0 0 4.25rem;
    aspect-ratio: 1;
    overflow: hidden;
    padding: 0;
    border: 2px solid var(--color-gray-800);
    border-radius: var(--radius-lg);
    opacity: 0.65;
    transition:
      border-color 180ms ease,
      opacity 180ms ease;
  }

  .article-gallery .gallery-thumbnail:is(:hover, :focus-visible),
  .article-gallery .gallery-thumbnail[aria-current='true'] {
    border-color: hsl(225 80% 70%);
    opacity: 1;
  }

  @media (width >= 48rem) {
    .article-gallery .gallery-desktop {
      display: block;
      columns: 2 18rem;
      column-gap: 1rem;
    }

    .article-gallery .gallery-mobile {
      display: none;
    }

    .article-gallery .gallery-item {
      display: inline-block;
      width: 100%;
      margin-bottom: 1rem;
      break-inside: avoid;
    }
  }

  @media (width >= 80rem) {
    .article-gallery .gallery-desktop {
      columns: 3 18rem;
    }
  }
</style>
