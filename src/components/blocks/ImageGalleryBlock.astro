---
import SanityPicture from 'astro-sanity-picture';
import Section from '../Section.astro';
import { imageBuilder } from '~/sanity/image';
import { Icon } from 'astro-icon/components';
import ImageCaptionButton from './ImageCaptionButton.astro';

export interface Props {
  node: {
    images: {
      caption: string;
      image: ImageWithMeta;
    }[];
  };
}

const { images } = Astro.props.node;
---

<Section width="mobile-full" data-block="image-gallery">
  <div class="article-gallery">
    {/* Desktop: Masonry grid */}
    <div class="masonry-grid hidden md:block">
      {
        images.map(({ caption, image }) => (
          <figure
            class="masonry-item article-image-frame relative"
            style={{
              aspectRatio: image.asset.metadata?.dimensions?.aspectRatio,
            }}
          >
            <SanityPicture
              src={image}
              imageUrlBuilder={imageBuilder}
              style={{
                width: '100%',
                height: '100%',
                objectFit: 'cover',
              }}
              sizes="(max-width: 1535px) calc(50vw - 3rem), 400px"
              widths={[320, 480, 640, 800]}
              sources={[{ options: { quality: 74 } }]}
              img={{
                alt: image.asset.alt || caption || '',
                class: 'w-full h-full object-cover',
                decoding: 'async',
                loading: 'lazy',
              }}
            />
            <ImageCaptionButton caption={caption} />
          </figure>
        ))
      }
    </div>

    {/* Mobile: Swiper gallery with thumbnails */}
    {
      images.length > 0 && (
        <div class="mobile-gallery md:hidden">
          {/* Main Swiper */}
          <div class="swiper gallery-main relative mb-3">
            <div class="swiper-wrapper">
              {images.map(({ caption, image }, index) => (
                <div class="swiper-slide">
                  <figure class="article-image-frame relative">
                    <SanityPicture
                      src={image}
                      imageUrlBuilder={imageBuilder}
                      style={{
                        width: '100%',
                        height: 'auto',
                      }}
                      sizes="100vw"
                      widths={[480, 640, 800, 960, 1280]}
                      sources={[{ options: { quality: 76 } }]}
                      img={{
                        alt: image.asset.alt || caption || '',
                        class: 'w-full h-auto',
                        decoding: 'async',
                        fetchpriority: index === 0 ? 'high' : 'auto',
                        loading: index === 0 ? 'eager' : 'lazy',
                      }}
                    />
                    <ImageCaptionButton caption={caption} />
                  </figure>
                </div>
              ))}
            </div>
            {/* Navigation buttons */}
            {images.length > 1 && (
              <div class="absolute top-0 left-0 z-10 flex w-full justify-between p-4">
                <button
                  class:list={[
                    'gallery-nav-prev',
                    'gallery-nav-button',
                    'disabled:cursor-not-allowed disabled:opacity-50',
                  ]}
                  aria-label="Previous image"
                >
                  <Icon name="mdi:chevron-left" size={20} />
                </button>
                <button
                  class:list={[
                    'gallery-nav-next',
                    'gallery-nav-button',
                    'disabled:cursor-not-allowed disabled:opacity-50',
                  ]}
                  aria-label="Next image"
                >
                  <Icon name="mdi:chevron-right" size={20} />
                </button>
              </div>
            )}
          </div>

          {/* Thumbnails Swiper */}
          {images.length > 1 && (
            <div class="swiper gallery-thumbs px-4">
              <div class="swiper-wrapper">
                {images.map(({ image, caption }) => (
                  <div class="swiper-slide">
                    <div class="gallery-thumbnail">
                      <SanityPicture
                        src={image}
                        imageUrlBuilder={imageBuilder}
                        style={{
                          width: '100%',
                          height: '100%',
                          objectFit: 'cover',
                        }}
                        sizes="80px"
                        widths={[80, 160]}
                        sources={[{ options: { quality: 70 } }]}
                        img={{
                          alt: image.asset.alt || caption || '',
                          class: 'w-full h-full object-cover',
                          decoding: 'async',
                          loading: 'lazy',
                        }}
                      />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )
    }
  </div>
</Section>

<script>
  const desktopGalleryMediaQuery = window.matchMedia('(min-width: 768px)');

  async function initMasonryGallery() {
    if (!desktopGalleryMediaQuery.matches) {
      return;
    }

    // Find this specific gallery grid
    const galleryGrids = document.querySelectorAll(
      '[data-block="image-gallery"] .masonry-grid',
    );

    if (galleryGrids.length === 0) {
      return;
    }

    const { default: Masonry } = await import('masonry-layout');

    galleryGrids.forEach((gridElement) => {
      const grid = gridElement as HTMLElement;
      // Skip if already initialized
      if (grid.dataset.masonryInitialized === 'true') {
        return;
      }
      grid.dataset.masonryInitialized = 'true';

      // Initialize Masonry immediately using aspect ratios
      // This prevents layout shift since items have aspect ratios set
      const initMasonry = () => {
        if (!Masonry) {
          console.error('Masonry library not available');
          return;
        }

        const msnry = new Masonry(gridElement as HTMLElement, {
          itemSelector: '.masonry-item',
          columnWidth: '.masonry-item',
          percentPosition: true,
          gutter: 16,
          transitionDuration: '0.3s',
        });

        if (!msnry) {
          return;
        }

        const layoutMethod = msnry.layout;
        if (!layoutMethod) {
          return;
        }

        // Initial layout - items have aspect ratios so this works immediately
        layoutMethod.call(msnry);

        // Re-layout when images load for fine-tuning (images might have slightly different dimensions)
        const images = gridElement.querySelectorAll('img');
        images.forEach((img) => {
          if (!img.complete) {
            img.addEventListener(
              'load',
              () => {
                layoutMethod.call(msnry);
              },
              { once: true },
            );
          }
        });
      };

      // Use requestAnimationFrame to ensure DOM is ready and aspect ratios are applied
      requestAnimationFrame(() => {
        initMasonry();
      });
    });
  }

  async function initMobileGallery() {
    if (desktopGalleryMediaQuery.matches) {
      return;
    }

    const mobileGalleries = document.querySelectorAll('.mobile-gallery');

    if (mobileGalleries.length === 0) {
      return;
    }

    const [{ default: Swiper }, { Navigation, Thumbs }] = await Promise.all([
      import('swiper'),
      import('swiper/modules'),
    ]);

    mobileGalleries.forEach((gallery) => {
      const mainSwiperEl = gallery.querySelector(
        '.gallery-main',
      ) as HTMLElement;
      const thumbsSwiperEl = gallery.querySelector(
        '.gallery-thumbs',
      ) as HTMLElement;

      if (!mainSwiperEl) return;

      // Skip if already initialized
      if (mainSwiperEl.dataset.swiperInitialized === 'true') {
        return;
      }
      mainSwiperEl.dataset.swiperInitialized = 'true';

      const slides = mainSwiperEl.querySelectorAll('.swiper-slide');
      const hasMultipleSlides = slides.length > 1;
      const canLoopMain = slides.length >= 4;

      // Initialize thumbnails swiper first (required for Thumbs module)
      let thumbsSwiper: InstanceType<typeof Swiper> | null = null;
      let thumbsLoop = false;
      if (thumbsSwiperEl) {
        const thumbsSlides = thumbsSwiperEl.querySelectorAll('.swiper-slide');
        thumbsLoop = thumbsSlides.length > 5;

        thumbsSwiper = new Swiper(thumbsSwiperEl, {
          spaceBetween: 12,
          slidesPerView: 3,
          centeredSlides: thumbsLoop,
          loop: thumbsLoop,
          freeMode: false,
          watchSlidesProgress: true,
          slideToClickedSlide: true,
          breakpoints: {
            375: {
              slidesPerView: 5,
            },
          },
        });
      }

      const nextEl = gallery.querySelector('.gallery-nav-next') as HTMLElement;
      const prevEl = gallery.querySelector('.gallery-nav-prev') as HTMLElement;

      // Initialize main swiper with Thumbs module
      const modules = [];
      if (thumbsSwiper) modules.push(Thumbs);
      if (hasMultipleSlides) modules.push(Navigation);

      const mainSwiper = new Swiper(mainSwiperEl, {
        modules: modules,
        spaceBetween: 16,
        autoHeight: true,
        loop: canLoopMain,
        loopAdditionalSlides: canLoopMain ? 2 : 0,
        rewind: hasMultipleSlides && !canLoopMain,
        navigation: hasMultipleSlides
          ? {
              nextEl,
              prevEl,
            }
          : undefined,
        thumbs: thumbsSwiper
          ? {
              swiper: thumbsSwiper,
            }
          : undefined,
      });

      // Ensure thumbnails center the active slide when main swiper changes
      if (thumbsSwiper && mainSwiper) {
        mainSwiper.on('slideChange', () => {
          const realIndex = mainSwiper.realIndex ?? mainSwiper.activeIndex;
          if (thumbsLoop) {
            thumbsSwiper.slideToLoop(realIndex);
          } else {
            thumbsSwiper.slideTo(realIndex);
          }
        });
      }
    });
  }

  function init() {
    void initMasonryGallery();
    void initMobileGallery();
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Also initialize on view transitions (Astro)
  document.addEventListener('astro:after-swap', init);
  desktopGalleryMediaQuery.addEventListener('change', init);
</script>

<style is:global>
  .article-gallery .masonry-grid {
    margin: 0 auto;
  }

  .article-gallery .article-image-frame {
    margin: 0;
    overflow: hidden;
    background-color: var(--color-gray-900);
  }

  @media (min-width: 64rem) {
    .article-gallery .article-image-frame {
      border-radius: var(--radius-lg);
    }
  }

  .article-gallery .masonry-item {
    width: calc(50% - 8px);
    margin-bottom: 16px;
    break-inside: avoid;
    position: relative;
    min-height: 0;
  }

  @media (max-width: 767px) {
    .article-gallery .masonry-item {
      width: 100%;
    }
  }

  /* Keep the mobile Swiper layout self-contained. */
  .article-gallery .mobile-gallery .swiper {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    padding: 0;
    overflow: hidden;
    list-style: none;
  }

  .article-gallery .swiper-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    height: 100%;
    box-sizing: content-box;
    transition-property: transform;
  }

  .article-gallery .swiper-slide {
    position: relative;
    display: block;
    flex-shrink: 0;
    width: 100%;
    height: 100%;
    transition-property: transform;
  }

  .article-gallery .swiper-autoheight,
  .article-gallery .swiper-autoheight .swiper-slide {
    height: auto;
  }

  .article-gallery .swiper-autoheight .swiper-wrapper {
    align-items: flex-start;
    transition-property: transform, height;
  }

  .article-gallery .gallery-thumbs {
    padding: 4px 1rem;
    overflow: hidden;
    max-width: 100%;
  }

  .article-gallery .gallery-thumbs .swiper-wrapper {
    align-items: center;
  }

  .article-gallery .gallery-thumbnail {
    aspect-ratio: 1;
    cursor: pointer;
    overflow: hidden;
    background-color: var(--color-gray-900);
    border: 2px solid var(--color-gray-800);
    border-radius: var(--radius-lg);
    opacity: 0.6;
    transition:
      opacity 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;
  }

  .article-gallery .gallery-thumbnail:hover {
    opacity: 1;
  }

  .article-gallery .gallery-nav-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    aspect-ratio: 1;
    border-radius: 0.5rem;
    background: rgb(4 13 18 / 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      background-color 500ms ease,
      opacity 500ms ease,
      transform 500ms ease;
  }

  .article-gallery .gallery-nav-button:hover {
    background: rgb(4 13 18 / 0.7);
  }

  .article-gallery .gallery-thumbs .swiper-slide {
    width: calc((100% - 24px) / 3);
    flex-shrink: 0;
  }

  @media (min-width: 375px) {
    .article-gallery .gallery-thumbs .swiper-slide {
      width: calc((100% - 48px) / 5);
    }
  }

  .article-gallery .swiper-slide-thumb-active .gallery-thumbnail {
    border-color: white;
    opacity: 1;
    transform: scale(1.05);
  }

  @media (min-width: 1280px) {
    .article-gallery .masonry-item {
      width: calc(33.333% - 11px);
    }
  }
</style>
