---
type SectionSpacing = 'sm' | 'md' | 'lg' | 'none';
type SectionWidth = 'default' | 'article';

export type Props = {
  spacing?: SectionSpacing;
  width?: SectionWidth;
};

const sectionSpacing: Record<SectionSpacing, string> = {
  sm: 'l-section-sm',
  md: 'l-section-md',
  lg: 'l-section-lg',
  none: '',
};

const sectionWidth: Record<SectionWidth, string> = {
  default: 'u-container u-container-screen-xl',
  article: 'u-container u-container-6xl',
};

const { spacing, width, ...props } = Astro.props;
const contentBlockSpacingReset = props['data-block']
  ? 'section-block-spacing-reset'
  : undefined;
---

<section
  class:list={[
    sectionSpacing[spacing ?? 'sm'],
    sectionWidth[width ?? 'default'],
    contentBlockSpacingReset,
  ]}
  {...props}
>
  <slot />
</section>

<style>
  .section-block-spacing-reset:first-child {
    margin-top: 0;
  }

  .section-block-spacing-reset:last-child {
    margin-bottom: 0;
  }
</style>
