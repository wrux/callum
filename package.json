{
  "name": "callum",
  "version": "2.0.0",
  "scripts": {
    "dev": "concurrently -k -n astro,studio -c cyan,magenta \"npm run dev:astro\" \"npm run studio:dev\"",
    "dev:astro": "astro dev --host=localhost --port=4322",
    "start": "npm run dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "studio:dev": "sanity dev --host=localhost --port=3333",
    "studio:build": "sanity build",
    "studio:deploy": "sanity deploy --url callum.sanity.studio"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Safari versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 iOS versions"
  ],
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@iconify-json/mdi": "^1.2.3",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "astro": "^7.0.2",
    "astro-icon": "^1.1.5",
    "astro-portabletext": "^0.13.0",
    "astro-sanity-picture": "^0.2.0",
    "astro-seo": "^1.1.0",
    "groq": "^5.28.0"
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/vision": "^6.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.1",
    "country-code-emoji": "^2.3.0",
    "cssnano": "^7.1.9",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanity": "^6.1.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.7",
    "sanity-plugin-dashboard-widget-document-list": "^2.1.3",
    "sanity-plugin-media": "^4.3.0",
    "styled-components": "^6.4.2"
  },
  "overrides": {
    "@vercel/frameworks": {
      "js-yaml": "^3.14.2"
    },
    "@vercel/routing-utils": {
      "path-to-regexp": "^6.3.0"
    },
    "@sanity/uuid": {
      "uuid": "^11.1.1"
    },
    "prismjs": "^1.30.0",
    "typeid-js": {
      "uuid": "^11.1.1"
    },
    "yaml-language-server": {
      "yaml": "^2.9.0"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
